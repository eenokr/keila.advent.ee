---
interface Props {
	text: string;
	link: string;
	variant?: 'primary' | 'secondary';
	external?: boolean;
	ariaLabel?: string;
}

const { text, link, variant = 'primary', external = false, ariaLabel } = Astro.props;
const base = import.meta.env.BASE_URL;

function withBase(href: string) {
	if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('tel:')) return href;
	if (href.startsWith('#')) return href;
	if (href === '/') return base;

	return `${base}${href.replace(/^\//, '')}`;
}
---

<a
	class={`button ${variant}`}
	href={withBase(link)}
	target={external ? '_blank' : undefined}
	rel={external ? 'noopener noreferrer' : undefined}
	aria-label={ariaLabel}
>
	{text}
</a>

<style>
	.button {
		border: 1.5px solid var(--color-primary);
		border-radius: 8px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-body);
		font-size: var(--button-font-size);
		font-weight: 600;
		letter-spacing: 0.01em;
		min-height: var(--button-height);
		padding: 0 var(--button-padding-x);
		text-decoration: none;
		transition: background 0.25s ease, border-color 0.25s ease,
		            color 0.25s ease, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
		            box-shadow 0.25s ease;
	}

	.button.primary {
		background: var(--color-primary);
		color: #ffffff;
		box-shadow: 0 2px 10px rgba(199, 102, 26, 0.28);
	}

	.button.secondary {
		background: transparent;
		color: var(--color-primary);
	}

	.button.primary:hover {
		background: var(--color-primary-dark);
		border-color: var(--color-primary-dark);
		box-shadow: 0 4px 18px rgba(158, 71, 15, 0.35);
		color: #ffffff;
		transform: translateY(-2px);
	}

	.button.secondary:hover {
		background: var(--color-primary);
		border-color: var(--color-primary);
		color: #ffffff;
		transform: translateY(-2px);
	}

	@media (max-width: 520px) {
		.button {
			width: 100%;
		}
	}
</style>
