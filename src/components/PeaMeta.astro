---
// Import the global.css file here so that it is included on
// all pages through the use of the <PeaMeta /> component.
import '../styles/global.css';
import '../styles/suurused.css';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import FallbackImage from '../assets/branding/kiriku-pilt.jpg';
import adventLogo from '../assets/branding/advent-logo.png';
import AtkinsonBold from '../assets/fonts/atkinson-bold.woff?url';
import AtkinsonRegular from '../assets/fonts/atkinson-regular.woff?url';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	siteTitle?: string;
	image?: ImageMetadata;
	imageAlt?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
const { title, description, siteTitle = SITE_TITLE, image = FallbackImage, imageAlt = siteTitle } = Astro.props;
const imageURL = new URL(image.src, Astro.url);

// Struktureeritud andmed (JSON-LD) — aitavad otsingumootoritel kogudust kui kohta tuvastada
// ja näidata rikastatud tulemusena. Andmed loetakse sisufailidest (uldinfo.md, kontakt.md).
const [siteEntry] = await getCollection('site');
const [contactEntry] = await getCollection('contact');
const siteData = siteEntry.data;
const contactData = contactEntry.data;
const phoneItem = contactData.contactItems.find((item) => item.href?.startsWith('tel:'));
const emailItem = contactData.contactItems.find((item) => item.href?.startsWith('mailto:'));
const [streetAddress, addressLocality = 'Keila'] = (contactData.address ?? 'Põllu 5, Keila')
	.split(',')
	.map((part) => part.trim());

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Church',
	name: siteData.title,
	url: Astro.site?.href,
	logo: new URL(adventLogo.src, Astro.site).href,
	image: new URL(image.src, Astro.site).href,
	description: siteData.description,
	...(emailItem ? { email: emailItem.value } : {}),
	...(phoneItem ? { telephone: phoneItem.value } : {}),
	address: {
		'@type': 'PostalAddress',
		streetAddress,
		addressLocality,
		addressRegion: 'Harjumaa',
		addressCountry: 'EE',
	},
	openingHoursSpecification: {
		'@type': 'OpeningHoursSpecification',
		dayOfWeek: 'Saturday',
		opens: '11:00',
	},
	sameAs: siteData.socials.map((social) => social.href),
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<meta name="theme-color" content="#fff8f0" />
<meta name="robots" content="index, follow" />
<link rel="preload" href={AtkinsonRegular} as="font" type="font/woff" crossorigin />
<link rel="preload" href={AtkinsonBold} as="font" type="font/woff" crossorigin />
<link rel="icon" type="image/png" href={`${base}favicon.png`} />
<link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`} />
<link rel="icon" href={`${base}favicon.ico`} sizes="any" />
<link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
<link rel="sitemap" href={`${base}sitemap-index.xml`} />
<meta name="generator" content={Astro.generator} />


<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content="et_EE" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />
<meta property="twitter:image:alt" content={imageAlt} />

<!-- Struktureeritud andmed (schema.org Church) -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />

<!-- Umami analüütika -->
<script defer src="https://cloud.umami.is/script.js" data-website-id="d0c37873-7a44-40e8-a80e-109c7cab1aa4"></script>
