---
// Import the global.css file here so that it is included on
// all pages through the use of the <PeaMeta /> component.
import '../styles/global.css';
import '../styles/suurused.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/branding/kiriku-pilt.jpg';
import AtkinsonBold from '../assets/fonts/atkinson-bold.woff?url';
import AtkinsonRegular from '../assets/fonts/atkinson-regular.woff?url';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	siteTitle?: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
const { title, description, siteTitle = SITE_TITLE, image = FallbackImage } = Astro.props;
const imageURL = new URL(image.src, Astro.url);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#fff8f0" />
<meta name="robots" content="index, follow" />
<link rel="preload" href={AtkinsonRegular} as="font" type="font/woff" crossorigin />
<link rel="preload" href={AtkinsonBold} as="font" type="font/woff" crossorigin />
<link rel="icon" type="image/png" href={`${base}favicon.png`} />
<link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`} />
<link rel="icon" href={`${base}favicon.ico`} sizes="any" />
<link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
<link rel="sitemap" href={`${base}sitemap-index.xml`} />
<meta name="generator" content={Astro.generator} />


<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content="et_EE" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />
<script>
((doc, win) => {
	const prefersReduced = win.matchMedia('(prefers-reduced-motion: reduce)').matches;
	if (prefersReduced) return;

	document.addEventListener('DOMContentLoaded', () => {
		doc.classList.add('animations-supported');

		const scrollObserver = new IntersectionObserver((entries, observer) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					observer.unobserve(entry.target);
				}
			});
		}, {
			threshold: 0.18,
		});

		Array.from(doc.querySelectorAll('.hero-copy, .gallery-carousel, .section-heading, .about-grid, .social-panel, .resource-group, .course-grid, .app-card, .visit-inner, article'))
			.forEach((element) => {
				element.classList.add('scroll-reveal');
				scrollObserver.observe(element);
			});
	});
})(document.documentElement, window);
</script>
