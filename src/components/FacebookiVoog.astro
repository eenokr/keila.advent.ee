---
interface Props {
	pageUrl?: string;
	title?: string;
}

const { pageUrl, title = 'Keila Adventkoguduse Facebooki postitused' } = Astro.props;

const normalizedPageUrl = pageUrl
	? pageUrl.trim().replace(/\/+$/u, '') + '/'
	: undefined;

const facebookPluginUrl = normalizedPageUrl
	? `https://www.facebook.com/plugins/page.php?${new URLSearchParams({
			href: normalizedPageUrl,
			tabs: 'timeline',
			width: '500',
			height: '700',
			small_header: 'true',
			adapt_container_width: 'true',
			hide_cover: 'false',
			show_facepile: 'false',
		}).toString()}`
	: undefined;
---

{normalizedPageUrl && facebookPluginUrl ? (
	<div class="facebook-feed">
		<div class="facebook-feed-frame-wrap">
			<iframe
				class="facebook-feed-frame"
				title={title}
				src={facebookPluginUrl}
				scrolling="no"
				frameborder="0"
				allowfullscreen={true}
				allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
				referrerpolicy="origin-when-cross-origin"
			></iframe>
		</div>
		<p class="facebook-feed-fallback">
			Kui Facebooki voog ei ilmu, <a href={normalizedPageUrl} target="_blank" rel="noopener noreferrer">ava postitused Facebookis</a>.
		</p>
	</div>
) : (
	<div class="facebook-feed-empty">Facebooki voo URL puudub või on vale.</div>
)}

<style>
	.facebook-feed,
	.facebook-feed-empty {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--facebook-feed-radius);
		box-shadow: var(--shadow-warm);
		box-sizing: border-box;
		margin-left: auto;
		margin-right: auto;
		width: min(100%, var(--facebook-feed-width));
	}

	.facebook-feed {
		--facebook-current-scale: min(var(--facebook-feed-scale), calc((100vw - 2 * var(--section-padding-x, 20px)) / var(--facebook-plugin-native-width)));
		overflow: hidden;
		padding: 0;
	}

	.facebook-feed-frame-wrap {
		height: calc(var(--facebook-feed-height) * var(--facebook-current-scale));
		overflow: hidden;
	}

	.facebook-feed-frame {
		border: 0;
		display: block;
		height: var(--facebook-feed-height);
		margin-left: calc((100% - var(--facebook-plugin-native-width)) / 2);
		transform: scale(var(--facebook-current-scale));
		transform-origin: top center;
		width: var(--facebook-plugin-native-width);
	}

	.facebook-feed-fallback {
		border-top: 1px solid var(--color-border);
		color: var(--color-text-muted);
		font-size: var(--facebook-feed-fallback-font-size);
		line-height: var(--facebook-feed-fallback-line-height);
		margin: 0;
		padding: var(--facebook-feed-fallback-padding);
		text-align: center;
	}

	.facebook-feed-fallback a {
		color: var(--color-primary);
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.facebook-feed-empty {
		color: var(--color-text-muted);
		padding: 1rem;
		text-align: center;
	}

	@media (max-width: 500px) {
		.facebook-feed,
		.facebook-feed-empty {
			max-width: 100%;
			width: 100%;
		}
	}
</style>
