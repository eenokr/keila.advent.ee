---
interface Props {
	title: string;
	label: string;
	href?: string;
}

const { title, label, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="resource-card" href={href}>
	<span>{label}</span>
	<h4>{title}</h4>
</Tag>

<style>
	.resource-card {
		background: #f7f4ef;
		border: 1px solid #e7dfd4;
		border-radius: 8px;
		color: inherit;
		display: block;
		min-height: 132px;
		padding: 24px;
		text-decoration: none;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	a.resource-card:hover {
		border-color: #cfc3b4;
		transform: translateY(-2px);
	}

	.resource-card span {
		color: #6d7f62;
		display: block;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		margin-bottom: 12px;
		text-transform: uppercase;
	}

	.resource-card h4 {
		color: #263f35;
		font-family: var(--font-heading);
		font-size: 1.14rem;
		font-weight: 600;
		line-height: 1.75;
		margin: 0;
	}
</style>
