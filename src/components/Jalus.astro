---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import adventLogo from '../assets/branding/advent-logo.png';

const today = new Date();
const [siteEntry] = await getCollection('site');
const site = siteEntry.data;
const iconPaths = {
	facebook:
		'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
	instagram:
		'M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2zm0 1.5A4 4 0 0 0 3.5 7.5v9A4 4 0 0 0 7.5 20.5h9A4 4 0 0 0 20.5 16.5v-9A4 4 0 0 0 16.5 3.5h-9zM17.5 6.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zm-5.5 1.5a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9zm0 1.5a3 3 0 1 0 0 6 3 3 0 0 0 0-6z',
	youtube:
		'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
};
---

<footer class="footer-main">
	<div class="footer-content">
		<div class="footer-info">
			<Image
				src={adventLogo}
				alt={site.logoAlt}
				width={54}
				height={57}
				class="footer-logo"
				loading="lazy"
				decoding="async"
				quality={90}
			/>
			<p class="footer-text">
				{site.footerText}
			</p>
			<p class="footer-contact">
				{site.footerContact}
			</p>
		</div>

		<div class="footer-socials">
			{site.socials.map((social) => (
				<a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label}>
					<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
						<path d={iconPaths[social.type]} />
					</svg>
				</a>
			))}
		</div>
	</div>

	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} {site.title}. {site.footerCopyright}</p>
	</div>
</footer>

<style>
	.footer-main {
		background: linear-gradient(135deg, var(--color-surface-warm) 0%, var(--color-surface) 100%);
		border-top: 1px solid var(--color-border);
		padding: var(--footer-padding-top) 20px var(--footer-padding-bottom);
		font-family: var(--font-body);
	}

	.footer-content {
		max-width: var(--site-max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		margin-bottom: 40px;
		align-items: start;
	}

	.footer-info {
		text-align: left;
	}

	.footer-logo {
		height: 54px;
		margin: 0 0 18px;
		width: auto;
	}

	.footer-text,
	.footer-contact {
		font-size: var(--footer-text-size);
		line-height: 1.6;
		margin: 0 0 10px;
		color: var(--color-text-soft);
	}

	.footer-contact {
		font-weight: 500;
	}

	.footer-socials {
		display: flex;
		justify-content: flex-end;
		gap: 25px;
	}

	.footer-socials a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		color: var(--color-accent);
		text-decoration: none;
		transition: color 0.3s ease, transform 0.3s ease;
	}

	.footer-socials a:hover {
		color: var(--color-primary-dark);
		transform: translateY(-3px);
	}

	.footer-bottom {
		max-width: var(--site-max-width);
		margin: 0 auto;
		padding-top: 30px;
		border-top: 1px solid var(--color-border);
		text-align: center;
	}

	.footer-bottom p {
		font-size: 0.85rem;
		color: #8a7768;
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer-main {
			padding: 40px 20px 30px;
		}

		.footer-content {
			grid-template-columns: 1fr;
			gap: 30px;
			margin-bottom: 30px;
		}

		.footer-info {
			text-align: center;
		}

		.footer-logo {
			margin-left: auto;
			margin-right: auto;
		}

		.footer-socials {
			justify-content: center;
		}
	}
</style>
