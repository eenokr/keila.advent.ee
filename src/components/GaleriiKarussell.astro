---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type Slide = {
	image: ImageMetadata;
	alt: string;
};

interface Props {
	slides: Slide[];
	intervalMs?: number;
}

const { slides, intervalMs = 4500 } = Astro.props;
const initialTrackIndex = slides.length > 1 ? slides.length : 0;
---

{slides.length > 0 && (
	<div class="gallery-carousel" data-gallery-carousel data-interval-ms={intervalMs}>
		<div class="gallery-slides" aria-live="polite" style={`--active-index: ${initialTrackIndex}; --drag-offset: 0px;`}>
			{slides.length > 1 && slides.map((slide) => (
				<div class="gallery-slide" aria-hidden="true">
					<div class="gallery-image">
						<Picture
							src={slide.image}
							formats={['webp']}
							widths={[720, 1200]}
							sizes="(max-width: 860px) calc(100vw - 36px), min(54vw, 820px)"
							alt=""
							loading="lazy"
							fetchpriority="auto"
							draggable="false"
							decoding="async"
							quality={82}
						/>
					</div>
				</div>
			))}
			{slides.map((slide, index) => (
				<div class:list={['gallery-slide', index === 0 && 'is-active']} data-gallery-slide>
					<div class="gallery-image">
						<Picture
							src={slide.image}
							formats={['webp']}
							widths={[720, 1200]}
							sizes="(max-width: 860px) calc(100vw - 36px), min(54vw, 820px)"
							alt={slide.alt}
							loading={index === 0 ? 'eager' : 'lazy'}
							fetchpriority={index === 0 ? 'high' : 'auto'}
							draggable="false"
							decoding={index === 0 ? 'sync' : 'async'}
							quality={82}
						/>
					</div>
				</div>
			))}
			{slides.length > 1 && slides.map((slide) => (
				<div class="gallery-slide" aria-hidden="true">
					<div class="gallery-image">
						<Picture
							src={slide.image}
							formats={['webp']}
							widths={[720, 1200]}
							sizes="(max-width: 860px) calc(100vw - 36px), min(54vw, 820px)"
							alt=""
							loading="lazy"
							fetchpriority="auto"
							draggable="false"
							decoding="async"
							quality={82}
						/>
					</div>
				</div>
			))}
		</div>

		<div class="gallery-controls" aria-label="Teadete valik">
			<div class="gallery-dots">
				{slides.map((_, index) => (
					<button
						class:list={['gallery-dot', index === 0 && 'is-active']}
						type="button"
						data-gallery-dot
						aria-label={`Näita teadet ${index + 1}`}
						aria-current={index === 0 ? 'true' : 'false'}
					/>
				))}
			</div>
		</div>
	</div>
)}

<script>
	const carousels = document.querySelectorAll('[data-gallery-carousel]');

	carousels.forEach((carousel) => {
		if (!(carousel instanceof HTMLElement)) return;

		const slides = Array.from(carousel.querySelectorAll('[data-gallery-slide]'));
		const dots = Array.from(carousel.querySelectorAll('[data-gallery-dot]'));
		const intervalMs = Number(carousel.dataset.intervalMs) || 4500;
		const swipeThreshold = 40;
		const wheelThreshold = 35;
		const slideTrack = carousel.querySelector('.gallery-slides');
		let activeIndex = 0;
		let startX = 0;
		let startY = 0;
		let isDragging = false;
		let wheelLocked = false;
		let timer;
		let snapTimer;
		let isWrapping = false;
		let transitionCleanup;

		if (!(slideTrack instanceof HTMLElement)) return;

		function getTrackIndex(index) {
			return slides.length > 1 ? slides.length + index : index;
		}

		function updateSlidePosition(trackIndex = getTrackIndex(activeIndex)) {
			slideTrack.style.setProperty('--active-index', String(trackIndex));
		}

		function setDragOffset(offset = 0) {
			slideTrack.style.setProperty('--drag-offset', `${offset}px`);
		}

		function snapToRealSlide(index = activeIndex) {
			carousel.classList.add('is-snapping');
			setDragOffset();
			updateSlidePosition(getTrackIndex(index));
			slideTrack.offsetHeight;
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					carousel.classList.remove('is-snapping');
					isWrapping = false;
				});
			});
		}

		function setActiveSlide(nextIndex) {
			if (slides.length === 0 || isWrapping) return;

			const normalizedIndex = (nextIndex + slides.length) % slides.length;
			const isForwardWrap = activeIndex === slides.length - 1 && nextIndex > activeIndex && normalizedIndex === 0;
			const isBackwardWrap = activeIndex === 0 && nextIndex < activeIndex && normalizedIndex === slides.length - 1;

			if (normalizedIndex === activeIndex) {
				setDragOffset();
				return;
			}

			window.clearTimeout(snapTimer);
			transitionCleanup?.();
			transitionCleanup = undefined;
			activeIndex = normalizedIndex;
			updateSlidePosition(
				isForwardWrap
					? slides.length * 2
					: isBackwardWrap
						? slides.length - 1
						: getTrackIndex(activeIndex),
			);
			setDragOffset();
			slides.forEach((slide, index) => {
				slide.classList.toggle('is-active', index === activeIndex);
			});

			dots.forEach((dot, index) => {
				const isActive = index === activeIndex;
				dot.classList.toggle('is-active', isActive);
				dot.setAttribute('aria-current', String(isActive));
			});

			if (isForwardWrap || isBackwardWrap) {
				isWrapping = true;
				const handleTransitionEnd = (event) => {
					if (event.propertyName !== 'transform') return;

					window.clearTimeout(snapTimer);
					transitionCleanup?.();
					transitionCleanup = undefined;
					snapToRealSlide(activeIndex);
				};

				transitionCleanup = () => {
					slideTrack.removeEventListener('transitionend', handleTransitionEnd);
				};
				slideTrack.addEventListener('transitionend', handleTransitionEnd);
				snapTimer = window.setTimeout(() => {
					transitionCleanup?.();
					transitionCleanup = undefined;
					snapToRealSlide(activeIndex);
				}, 1200);
			}
		}

		function stopTimer() {
			window.clearInterval(timer);
		}

		function startTimer() {
			stopTimer();
			if (slides.length > 1) {
				timer = window.setInterval(() => setActiveSlide(activeIndex + 1), intervalMs);
			}
		}

		dots.forEach((dot, index) => {
			dot.addEventListener('pointerdown', (event) => {
				event.stopPropagation();
			});

			dot.addEventListener('click', (event) => {
				event.stopPropagation();
				setActiveSlide(index);
				startTimer();
			});
		});

		carousel.addEventListener('pointerdown', (event) => {
			if (isWrapping) return;

			startX = event.clientX;
			startY = event.clientY;
			isDragging = true;
			carousel.classList.add('is-dragging');
			carousel.setPointerCapture?.(event.pointerId);
			stopTimer();
		});

		carousel.addEventListener('pointermove', (event) => {
			if (!isDragging) return;

			const deltaX = event.clientX - startX;
			const deltaY = event.clientY - startY;

			if (Math.abs(deltaX) > Math.abs(deltaY)) {
				setDragOffset(deltaX);
			}
		});

		carousel.addEventListener('pointerup', (event) => {
			const deltaX = event.clientX - startX;
			const deltaY = event.clientY - startY;
			isDragging = false;
			carousel.classList.remove('is-dragging');

			if (deltaX < -swipeThreshold && Math.abs(deltaX) > Math.abs(deltaY)) {
				setActiveSlide(activeIndex + 1);
			} else if (deltaX > swipeThreshold && Math.abs(deltaX) > Math.abs(deltaY)) {
				setActiveSlide(activeIndex - 1);
			} else {
				setDragOffset();
			}

			startTimer();
		});

		carousel.addEventListener('pointercancel', () => {
			isDragging = false;
			carousel.classList.remove('is-dragging');
			setDragOffset();
			startTimer();
		});
		carousel.addEventListener('wheel', (event) => {
			if (Math.abs(event.deltaX) <= Math.abs(event.deltaY) || wheelLocked || isWrapping) {
				return;
			}

			event.preventDefault();
			stopTimer();

			if (event.deltaX > wheelThreshold) {
				setActiveSlide(activeIndex + 1);
				wheelLocked = true;
				window.setTimeout(() => {
					wheelLocked = false;
				}, 450);
			} else if (event.deltaX < -wheelThreshold) {
				setActiveSlide(activeIndex - 1);
				wheelLocked = true;
				window.setTimeout(() => {
					wheelLocked = false;
				}, 450);
			}

			startTimer();
		}, { passive: false });
		carousel.addEventListener('mouseenter', stopTimer);
		carousel.addEventListener('mouseleave', startTimer);
		carousel.addEventListener('focusin', stopTimer);
		carousel.addEventListener('focusout', startTimer);

		updateSlidePosition();
		startTimer();
	});
</script>

<style>
	.gallery-carousel {
		aspect-ratio: 16 / 10;
		background: transparent;
		border-radius: 8px;
		box-shadow: var(--shadow-warm);
		overflow: hidden;
		position: relative;
		touch-action: pan-y;
		user-select: none;
	}

	.gallery-slides,
	.gallery-image,
	.gallery-image :global(picture),
	.gallery-slide :global(picture),
	.gallery-slide :global(img) {
		height: 100%;
		width: 100%;
	}

	.gallery-slides {
		--active-index: 0;
		--drag-offset: 0px;
		display: flex;
		transform: translateX(calc(var(--active-index) * -100% + var(--drag-offset)));
		transition: transform 0.95s cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.gallery-carousel.is-dragging .gallery-slides {
		transition: none;
	}

	.gallery-carousel.is-snapping .gallery-slides {
		transition: none;
	}

	.gallery-slide {
		flex: 0 0 100%;
		height: 100%;
		min-width: 100%;
		opacity: 1;
		position: relative;
		width: 100%;
	}

	.gallery-slide.is-active {
		z-index: 1;
	}

	.gallery-slide :global(picture) {
		display: block;
	}

	.gallery-image {
		inset: 0;
		position: absolute;
	}

	.gallery-image {
		z-index: 1;
	}

	.gallery-slide :global(img) {
		-webkit-user-drag: none;
		pointer-events: none;
		user-select: none;
	}

	.gallery-image :global(img) {
		object-fit: cover;
	}

	.gallery-controls {
		align-items: center;
		display: flex;
		gap: 10px;
		right: 22px;
		top: 22px;
		position: absolute;
		z-index: 3;
	}

	.gallery-dots {
		align-items: center;
		display: flex;
		gap: 10px;
	}

	.gallery-dot {
		background: rgba(255, 255, 255, 0.48);
		border: 0;
		border-radius: 999px;
		box-shadow: 0 1px 8px rgba(32, 24, 20, 0.14);
		cursor: pointer;
		height: 13px;
		padding: 0;
		transition: background-color 0.2s ease, transform 0.2s ease, height 0.2s ease, width 0.2s ease;
		width: 13px;
	}

	.gallery-dot.is-active {
		background: rgba(255, 255, 255, 0.95);
		box-shadow: 0 2px 10px rgba(32, 24, 20, 0.2);
		transform: scale(1.12);
	}

	.gallery-dot:hover,
	.gallery-dot:focus-visible {
		background: rgba(255, 255, 255, 0.88);
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-slides,
		.gallery-dot {
			transition: none;
		}
	}

	@media (max-width: 860px) {
		.gallery-carousel {
			aspect-ratio: 16 / 11;
		}
	}

	@media (max-width: 520px) {
		.gallery-controls {
			right: 14px;
			top: 14px;
		}
	}
</style>
