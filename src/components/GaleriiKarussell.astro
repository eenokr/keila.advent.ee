---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type StaticSlide = { image: ImageMetadata; alt: string };
type DriveSlide = { src: string; srcset?: string; width: number; height: number; alt: string };
type Slide = StaticSlide | DriveSlide;

function isStatic(s: Slide): s is StaticSlide {
	return 'image' in s;
}

interface Props {
	slides: Slide[];
	intervalMs?: number;
	controlsLabel?: string;
	dotLabel?: string;
	aspectRatio?: string;
	showDots?: boolean;
}

const { slides, intervalMs = 4500, controlsLabel = 'Piltide valik', dotLabel = 'Näita pilti', aspectRatio = '4 / 3', showDots = true } = Astro.props;
const firstSlide = slides[0];
const lastSlide = slides[slides.length - 1];
const initialTrackIndex = slides.length > 1 ? 1 : 0;
---

{slides.length > 0 && (
	<div class="gallery-carousel" data-gallery-carousel data-interval-ms={intervalMs}>
		<div class="gallery-viewport" style={`--carousel-aspect-ratio: ${aspectRatio}`}>
		<div class="gallery-slides" aria-live="polite" style={`--active-index: ${initialTrackIndex}; --drag-offset: 0px;`}>
			{slides.length > 1 && lastSlide && (
				<div class="gallery-slide" aria-hidden="true">
					<div class="gallery-image">
						{isStatic(lastSlide)
							? <Image src={lastSlide.image} width={1200} format="webp" alt="" loading="lazy" fetchpriority="auto" draggable="false" decoding="async" quality={92} />
							: <img src={lastSlide.src} srcset={lastSlide.srcset} width={lastSlide.width} height={lastSlide.height} alt="" loading="lazy" fetchpriority="auto" draggable="false" decoding="async" />
						}
					</div>
				</div>
			)}
			{slides.map((slide, index) => (
				<div class:list={['gallery-slide', index === 0 && 'is-active']} data-gallery-slide>
					<div class="gallery-image">
						{isStatic(slide)
							? <Image src={slide.image} width={1200} format="webp" alt={slide.alt} loading={index === 0 ? 'eager' : 'lazy'} fetchpriority={index === 0 ? 'high' : 'auto'} draggable="false" decoding={index === 0 ? 'sync' : 'async'} quality={92} />
							: <img src={slide.src} srcset={slide.srcset} width={slide.width} height={slide.height} alt={slide.alt} loading={index === 0 ? 'eager' : 'lazy'} fetchpriority={index === 0 ? 'high' : 'auto'} draggable="false" decoding={index === 0 ? 'sync' : 'async'} />
						}
					</div>
				</div>
			))}
			{slides.length > 1 && firstSlide && (
				<div class="gallery-slide" aria-hidden="true">
					<div class="gallery-image">
						{isStatic(firstSlide)
							? <Image src={firstSlide.image} width={1200} format="webp" alt="" loading="lazy" fetchpriority="auto" draggable="false" decoding="async" quality={92} />
							: <img src={firstSlide.src} srcset={firstSlide.srcset} width={firstSlide.width} height={firstSlide.height} alt="" loading="lazy" fetchpriority="auto" draggable="false" decoding="async" />
						}
					</div>
				</div>
			)}
		</div>
		</div>

		{showDots && (
			<div class="gallery-controls" aria-label={controlsLabel}>
				<div class="gallery-dots">
					{slides.map((_, index) => (
						<button
							class:list={['gallery-dot', index === 0 && 'is-active']}
							type="button"
							data-gallery-dot
							aria-label={`${dotLabel} ${index + 1}`}
							aria-current={index === 0 ? 'true' : 'false'}
						/>
					))}
				</div>
			</div>
		)}
	</div>
)}

<script>
	const carousels = document.querySelectorAll('[data-gallery-carousel]');

	carousels.forEach((carousel) => {
		if (!(carousel instanceof HTMLElement)) return;

		const slides = Array.from(carousel.querySelectorAll('[data-gallery-slide]'));
		const dots = Array.from(carousel.querySelectorAll('[data-gallery-dot]'));
		const intervalMs = Number(carousel.dataset.intervalMs) || 4500;
		const swipeThreshold = 40;
		const wheelThreshold = 35;
		const slideTrack = carousel.querySelector('.gallery-slides');
		let activeIndex = 0;
		let startX = 0;
		let startY = 0;
		let isDragging = false;
		let wheelLocked = false;
		let timer;
		let snapTimer;
		let isWrapping = false;
		let transitionCleanup;

		if (!(slideTrack instanceof HTMLElement)) return;

		function getTrackIndex(index) {
			return slides.length > 1 ? index + 1 : index;
		}

		function updateSlidePosition(trackIndex = getTrackIndex(activeIndex)) {
			slideTrack.style.setProperty('--active-index', String(trackIndex));
		}

		function setDragOffset(offset = 0) {
			slideTrack.style.setProperty('--drag-offset', `${offset}px`);
		}

		function preloadNearby(index: number) {
			[-1, 0, 1].forEach((offset) => {
				const i = (index + offset + slides.length) % slides.length;
				const img = slides[i]?.querySelector('img');
				if (img && img.getAttribute('loading') === 'lazy') {
					img.setAttribute('loading', 'eager');
				}
			});
		}

		function snapToRealSlide(index = activeIndex) {
			carousel.classList.add('is-snapping');
			setDragOffset();
			updateSlidePosition(getTrackIndex(index));
			slideTrack.offsetHeight;
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					carousel.classList.remove('is-snapping');
					isWrapping = false;
				});
			});
		}

		function setActiveSlide(nextIndex) {
			if (slides.length === 0 || isWrapping) return;

			const normalizedIndex = (nextIndex + slides.length) % slides.length;
			const isForwardWrap = activeIndex === slides.length - 1 && nextIndex > activeIndex && normalizedIndex === 0;
			const isBackwardWrap = activeIndex === 0 && nextIndex < activeIndex && normalizedIndex === slides.length - 1;

			if (normalizedIndex === activeIndex) {
				setDragOffset();
				return;
			}

			window.clearTimeout(snapTimer);
			transitionCleanup?.();
			transitionCleanup = undefined;
			activeIndex = normalizedIndex;
			updateSlidePosition(
				isForwardWrap
					? slides.length + 1
					: isBackwardWrap
						? 0
						: getTrackIndex(activeIndex),
			);
			setDragOffset();
			slides.forEach((slide, index) => {
				slide.classList.toggle('is-active', index === activeIndex);
			});

			dots.forEach((dot, index) => {
				const isActive = index === activeIndex;
				dot.classList.toggle('is-active', isActive);
				dot.setAttribute('aria-current', String(isActive));
			});

			preloadNearby(normalizedIndex);

			if (isForwardWrap || isBackwardWrap) {
				isWrapping = true;
				const handleTransitionEnd = (event) => {
					if (event.propertyName !== 'transform') return;

					window.clearTimeout(snapTimer);
					transitionCleanup?.();
					transitionCleanup = undefined;
					snapToRealSlide(activeIndex);
				};

				transitionCleanup = () => {
					slideTrack.removeEventListener('transitionend', handleTransitionEnd);
				};
				slideTrack.addEventListener('transitionend', handleTransitionEnd);
				snapTimer = window.setTimeout(() => {
					transitionCleanup?.();
					transitionCleanup = undefined;
					snapToRealSlide(activeIndex);
				}, 1200);
			}
		}

		function stopTimer() {
			window.clearInterval(timer);
		}

		function startTimer() {
			stopTimer();
			if (slides.length > 1) {
				timer = window.setInterval(() => setActiveSlide(activeIndex + 1), intervalMs);
			}
		}

		dots.forEach((dot, index) => {
			dot.addEventListener('pointerdown', (event) => {
				event.stopPropagation();
			});

			dot.addEventListener('click', (event) => {
				event.stopPropagation();
				setActiveSlide(index);
				startTimer();
			});
		});

		carousel.addEventListener('pointerdown', (event) => {
			if (isWrapping) return;

			startX = event.clientX;
			startY = event.clientY;
			isDragging = true;
			carousel.classList.add('is-dragging');
			carousel.setPointerCapture?.(event.pointerId);
			stopTimer();
		});

		carousel.addEventListener('pointermove', (event) => {
			if (!isDragging) return;

			const deltaX = event.clientX - startX;
			const deltaY = event.clientY - startY;

			if (Math.abs(deltaX) > Math.abs(deltaY)) {
				setDragOffset(deltaX);
			}
		});

		carousel.addEventListener('pointerup', (event) => {
			const deltaX = event.clientX - startX;
			const deltaY = event.clientY - startY;
			isDragging = false;
			carousel.classList.remove('is-dragging');

			if (deltaX < -swipeThreshold && Math.abs(deltaX) > Math.abs(deltaY)) {
				setActiveSlide(activeIndex + 1);
			} else if (deltaX > swipeThreshold && Math.abs(deltaX) > Math.abs(deltaY)) {
				setActiveSlide(activeIndex - 1);
			} else {
				setDragOffset();
			}

			startTimer();
		});

		carousel.addEventListener('pointercancel', () => {
			isDragging = false;
			carousel.classList.remove('is-dragging');
			setDragOffset();
			startTimer();
		});
		carousel.addEventListener('wheel', (event) => {
			if (Math.abs(event.deltaX) <= Math.abs(event.deltaY) || wheelLocked || isWrapping) {
				return;
			}

			event.preventDefault();
			stopTimer();

			if (event.deltaX > wheelThreshold) {
				setActiveSlide(activeIndex + 1);
				wheelLocked = true;
				window.setTimeout(() => {
					wheelLocked = false;
				}, 450);
			} else if (event.deltaX < -wheelThreshold) {
				setActiveSlide(activeIndex - 1);
				wheelLocked = true;
				window.setTimeout(() => {
					wheelLocked = false;
				}, 450);
			}

			startTimer();
		}, { passive: false });
		carousel.addEventListener('mouseenter', stopTimer);
		carousel.addEventListener('mouseleave', startTimer);
		carousel.addEventListener('focusin', stopTimer);
		carousel.addEventListener('focusout', startTimer);

		updateSlidePosition();

		// Autoplay ja piltide eellaadimine käivituvad alles siis, kui karussell on (peaaegu)
		// vaateväljas. Nii ei jää alumine galerii enam enne kerimist tühjaks ega tööta
		// asjatult ekraanilt väljas.
		const visibility = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					preloadNearby(activeIndex);
					startTimer();
				} else {
					stopTimer();
				}
			});
		}, { rootMargin: '300px 0px' });
		visibility.observe(carousel);
	});
</script>

<style>
	.gallery-carousel {
		align-items: center;
		display: flex;
		flex-direction: column;
		width: min(100%, var(--gallery-panel-width));
	}

	.gallery-viewport {
		aspect-ratio: var(--carousel-aspect-ratio, 4 / 3);
		background: transparent;
		border-radius: var(--gallery-border-radius);
		box-shadow: var(--shadow-warm);
		height: auto;
		/* Safari overflow+border-radius fix */
		-webkit-mask-image: -webkit-radial-gradient(white, black);
		mask-image: radial-gradient(white, black);
		overflow: hidden;
		position: relative;
		touch-action: pan-y;
		-webkit-user-select: none;
		user-select: none;
		width: 100%;
	}

	.gallery-slides,
	.gallery-image,
	.gallery-image :global(picture),
	.gallery-slide :global(picture),
	.gallery-slide :global(img) {
		height: 100%;
		width: 100%;
	}

	.gallery-slides {
		--active-index: 0;
		--drag-offset: 0px;
		display: flex;
		-webkit-transform: translateX(calc(var(--active-index) * -100% + var(--drag-offset)));
		transform: translateX(calc(var(--active-index) * -100% + var(--drag-offset)));
		-webkit-transition: -webkit-transform 0.95s cubic-bezier(0.2, 0.8, 0.2, 1);
		transition: transform 0.95s cubic-bezier(0.2, 0.8, 0.2, 1);
		will-change: transform;
	}

	.gallery-carousel.is-dragging .gallery-slides {
		-webkit-transition: none;
		transition: none;
	}

	.gallery-carousel.is-snapping .gallery-slides {
		-webkit-transition: none;
		transition: none;
	}

	.gallery-slide {
		flex: 0 0 100%;
		height: 100%;
		min-width: 100%;
		opacity: 1;
		position: relative;
		width: 100%;
	}

	.gallery-slide.is-active {
		-webkit-transform: translateZ(0);
		transform: translateZ(0);
		z-index: 1;
	}

	.gallery-slide :global(picture) {
		display: block;
	}

	.gallery-image {
		inset: 0;
		position: absolute;
	}

	.gallery-image {
		z-index: 1;
	}

	.gallery-slide :global(img) {
		-webkit-user-drag: none;
		pointer-events: none;
		user-select: none;
	}

	.gallery-image :global(img) {
		object-fit: contain;
	}

	.gallery-controls {
		align-items: center;
		display: flex;
		gap: var(--gallery-dot-gap);
		justify-content: flex-end;
		margin-top: 14px;
		padding-right: 4px;
		width: 100%;
	}

	.gallery-dots {
		align-items: center;
		display: flex;
		gap: var(--gallery-dot-gap);
	}

	.gallery-dot {
		background: rgba(199, 102, 26, 0.28);
		border: 0;
		border-radius: 999px;
		cursor: pointer;
		height: var(--gallery-dot-size);
		padding: 0;
		transition: background-color 0.2s ease, transform 0.2s ease, height 0.2s ease, width 0.2s ease;
		width: var(--gallery-dot-size);
	}

	.gallery-dot.is-active {
		background: var(--color-primary);
		transform: scale(1.15);
	}

	.gallery-dot:hover,
	.gallery-dot:focus-visible {
		background: rgba(199, 102, 26, 0.55);
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-slides,
		.gallery-dot {
			transition: none;
		}
	}
</style>
