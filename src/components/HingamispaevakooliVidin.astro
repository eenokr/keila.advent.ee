---
import { getCollection } from 'astro:content';
const [entry] = await getCollection('koduleht', (e) => e.id === 'oppetuki-app');
const { eyebrow, title, description } = entry?.data ?? {};

// Determine current active quarter (same logic as client-side script)
const QUARTERS = [
	{ id: '2026-01', start: new Date(2026, 0, 3)  },
	{ id: '2026-02', start: new Date(2026, 2, 28) },
	{ id: '2026-03', start: new Date(2026, 5, 27) },
	{ id: '2026-04', start: new Date(2026, 8, 26) },
	{ id: '2027-01', start: new Date(2026, 11, 26) },
	{ id: '2027-02', start: new Date(2027, 2, 27) },
];

const now = new Date();
const daysSinceSat = (now.getDay() + 1) % 7;
const thisSat = new Date(now);
thisSat.setDate(now.getDate() - daysSinceSat);
thisSat.setHours(12, 0, 0, 0);

let activeId = QUARTERS[0].id;
for (const q of QUARTERS) {
	const s = new Date(q.start);
	s.setHours(12, 0, 0, 0);
	if (thisSat >= s) activeId = q.id;
}

const quarterLink = `https://sabbath-school.adventech.io/et/${activeId}/`;
const allQuartersLink = `https://sabbath-school.adventech.io/et/`;

const ghBase = `https://raw.githubusercontent.com/Adventech/sabbath-school-lessons/master/src/et/${activeId}`;
const coverUrl = `${ghBase}/cover.png`;

const activeIndex = QUARTERS.findIndex(q => q.id === activeId);
const ghFutureBase = `https://raw.githubusercontent.com/Adventech/sabbath-school-lessons/master/src/et`;
const ghHistBase   = `https://raw.githubusercontent.com/Adventech/sabbath-school-lessons-2016-2026/master/src/et`;

async function coverExists(url: string): Promise<boolean> {
	try {
		const r = await fetch(url, { method: 'HEAD' });
		return r.ok;
	} catch { return false; }
}

// Check future quarters in parallel
const futureQuarters = QUARTERS.slice(activeIndex + 1);
const futureChecks = await Promise.all(
	futureQuarters.map(q => {
		const url = `${ghFutureBase}/${q.id}/cover.png`;
		return coverExists(url).then(ok => ok ? { id: q.id, url } : null);
	})
);

const archiveCovers: { id: string; url: string }[] = futureChecks.filter(Boolean) as { id: string; url: string }[];

// Fill remaining slots with known past quarters
const pastIds = ['2025-04', '2025-03', '2025-02', '2025-01', '2024-04', '2024-03'];
for (const id of pastIds) {
	if (archiveCovers.length >= 4) break;
	archiveCovers.push({ id, url: `${ghHistBase}/${id}/cover.png` });
}
const nextCovers = archiveCovers.slice(0, 4);

let quarterTitle: string | null = null;

try {
	const infoText = await fetch(`${ghBase}/info.yml`).then(r => r.ok ? r.text() : '');
	const titleMatch = infoText.match(/title:\s*['"](.+?)['"]/);
	quarterTitle = titleMatch?.[1] ?? null;
} catch (_) {
	// metadata is optional
}
---

<section class="ss-section" id="oppetykk">
	<div class="ss-inner">

		<div class="ss-left">
			{eyebrow && <p class="ss-eyebrow">{eyebrow}</p>}
			{title && <h2 class="ss-app-title">{title}</h2>}
			{description && <p class="ss-app-desc">{description}</p>}
			<div class="ss-badges">
				<a
					class="ss-badge"
					href="https://apps.apple.com/us/app/sabbath-school-pm/id895272167"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Lae alla App Store'ist"
				>
					<svg width="22" height="26" viewBox="0 0 22 26" fill="white" aria-hidden="true">
						<path d="M18.07 13.72c-.03-3.16 2.58-4.69 2.7-4.77-1.47-2.16-3.76-2.45-4.57-2.48-1.95-.2-3.8 1.15-4.79 1.15-.99 0-2.52-1.12-4.14-1.09-2.13.03-4.1 1.24-5.2 3.14-2.22 3.86-.57 9.57 1.59 12.7 1.06 1.53 2.32 3.25 3.98 3.19 1.6-.07 2.2-1.03 4.13-1.03 1.93 0 2.48 1.03 4.17.99 1.72-.03 2.81-1.56 3.86-3.1a14.6 14.6 0 0 0 1.75-3.58c-.04-.01-3.44-1.32-3.48-5.12zM14.87 4.3C15.74 3.24 16.33 1.78 16.17 0c-1.27.05-2.82.85-3.73 1.89-.82.92-1.54 2.4-1.35 3.82 1.42.1 2.87-.72 3.78-1.41z"/>
					</svg>
					<span class="ss-badge-text">
						<small>Lae alla</small>
						App Store'ist
					</span>
				</a>
				<a
					class="ss-badge"
					href="https://play.google.com/store/apps/details?id=com.cryart.sabbathschool&hl=en"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Lae alla Google Playst"
				>
					<svg width="22" height="24" viewBox="0 0 22 24" aria-hidden="true">
						<path d="M1.22.43C.88.8.68 1.37.68 2.1v19.8c0 .73.2 1.3.54 1.67l.09.08 11.1-11.1v-.26L1.31.35l-.09.08z" fill="#4FC3F7"/>
						<path d="M15.83 15.97l-3.42-3.42v-.27l3.42-3.42.08.04 4.05 2.3c1.16.66 1.16 1.73 0 2.39l-4.05 2.3-.08.08z" fill="#FFCA28"/>
						<path d="M15.91 15.89L12.41 12.4 1.22 23.57c.38.4 1.01.45 1.72.05l12.97-7.73" fill="#F44336"/>
						<path d="M15.91 8.11L2.94.38C2.23-.02 1.6.03 1.22.43L12.41 11.6l3.5-3.5z" fill="#4CAF50"/>
					</svg>
					<span class="ss-badge-text">
						<small>Lae alla</small>
						Google Playst
					</span>
				</a>
			</div>
		</div>

		<div class="ss-right">
			<div class="ss-cards">
				<a
					href={quarterLink}
					target="_blank"
					rel="noopener noreferrer"
					class={`ss-cover-card${coverUrl ? '' : ' ss-cover-card--empty'}`}
					aria-label={`Ava ${quarterTitle ?? 'selle kvartali õppetükk'} sabbath-school.adventech.io lehel`}
				>
					{coverUrl && <img src={coverUrl} alt={quarterTitle ?? 'Kvartali õppetükk kaas'} class="ss-cover-img" loading="eager" />}
					<div class="ss-cover-cta">
						<span class="ss-cover-cta-label">Ava õppetükk</span>
						<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
							<path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
				</a>
				<a
					href={allQuartersLink}
					target="_blank"
					rel="noopener noreferrer"
					class="ss-cover-card ss-cover-more"
					aria-label="Vaata õppetükkide arhiivi"
				>
					<div class="ss-cover-grid">
						{nextCovers.map(c => (
							<img src={c.url} alt={c.id} class="ss-cover-thumb" loading="lazy" />
						))}
					</div>
					<div class="ss-cover-cta">
						<span class="ss-cover-cta-label">Arhiiv</span>
						<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
							<path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
				</a>
			</div>
		</div>

	</div>
</section>

<style>
	.ss-section {
		background: var(--color-page);
		padding: var(--section-padding-y) var(--section-padding-x);
	}

	.ss-inner {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 64px;
		align-items: center;
		max-width: var(--site-max-width);
		margin: 0 auto;
	}

	.ss-left {
		position: static;
	}

	.ss-eyebrow {
		color: var(--color-accent);
		font-family: var(--font-heading);
		font-size: var(--eyebrow-font-size);
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 14px;
		text-transform: uppercase;
	}

	.ss-app-title {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: clamp(1.9rem, 2.6vw, 2.8rem);
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.05;
		margin: 0 0 20px;
	}

	.ss-app-desc {
		color: var(--color-text-soft);
		font-size: 1.125rem;
		line-height: 1.75;
		margin: 0 0 32px;
	}

	.ss-badges {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		gap: 10px;
	}

	.ss-badge {
		align-items: center;
		background: #000;
		border: 1px solid rgba(255,255,255,0.15);
		border-radius: 10px;
		color: #fff;
		display: flex;
		gap: 12px;
		padding: 10px 18px;
		text-decoration: none;
		transition: background 0.18s ease, transform 0.18s ease;
		width: fit-content;
		min-width: 180px;
	}

	.ss-badge:hover {
		background: #1a1a1a;
		transform: translateY(-1px);
	}

	.ss-badge-text {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}

	.ss-badge-text small {
		font-size: 0.6875rem;
		font-weight: 400;
		letter-spacing: 0.02em;
		opacity: 0.85;
	}

	.ss-badge-text {
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.2;
	}

	.ss-right {
		min-width: 0;
	}

	.ss-cards {
		display: flex;
		gap: 14px;
		align-items: stretch;
	}

	.ss-intro {
		margin-bottom: 24px;
	}

	.ss-heading {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: var(--section-title-size);
		font-weight: 600;
		line-height: 1.1;
		margin: 0 0 8px;
	}

	.ss-quarter-date {
		color: var(--color-text-soft);
		font-size: 0.875rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		margin: 0;
		text-transform: uppercase;
	}

	.ss-cover-card {
		display: block;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: var(--shadow-warm);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
		text-decoration: none;
		position: relative;
		flex: 1 1 0;
		min-width: 0;
	}

	.ss-cover-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 32px 80px rgba(117, 62, 19, 0.22);
	}

	.ss-cover-card--empty {
		aspect-ratio: 3 / 4;
		background: var(--color-surface-warm);
		border: 2px dashed var(--color-border);
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
	}

	.ss-cover-img {
		display: block;
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.ss-cover-cta {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		background: var(--color-primary);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 14px 16px;
		font-family: var(--font-heading);
		font-size: 0.9375rem;
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	.ss-cover-card--empty .ss-cover-cta {
		position: static;
		width: 100%;
	}

	.ss-cover-more {
		display: flex;
		flex-direction: column;
	}

	.ss-cover-more .ss-cover-cta {
		position: static;
		flex-shrink: 0;
	}

	.ss-cover-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		grid-template-rows: 1fr 1fr;
		flex: 1;
		min-height: 0;
	}

	.ss-cover-thumb {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.ss-footer {
		align-items: center;
		display: flex;
		gap: 16px;
		justify-content: space-between;
		margin-top: 16px;
	}

	.ss-link {
		align-items: center;
		color: var(--color-primary);
		display: inline-flex;
		font-family: var(--font-heading);
		font-size: 0.9375rem;
		font-weight: 600;
		gap: 6px;
		text-decoration: none;
		transition: color 0.15s, transform 0.15s;
	}

	.ss-link:hover {
		color: var(--color-primary-dark);
		transform: translateX(2px);
	}

	.ss-credit {
		color: var(--color-text-soft);
		font-size: 0.75rem;
	}

	@media (max-width: 860px) {
		.ss-inner {
			grid-template-columns: 1fr;
			gap: 32px;
			align-items: start;
		}

		.ss-cards {
			max-width: 440px;
		}
	}

	@media (max-width: 640px) {
		.ss-section { padding: var(--section-padding-y) var(--section-padding-x); }
		.ss-cards { max-width: 100%; }
		.ss-badge { flex: 1; min-width: 0; }
	}
</style>
