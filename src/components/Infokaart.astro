---
interface Props {
	title: string;
	description: string;
	icon?: string;
	iconAlt?: string;
}

const { title, description, icon, iconAlt } = Astro.props;

const iconSrc = icon
	? icon.startsWith("/")
		? `${import.meta.env.BASE_URL}${icon.slice(1)}`
		: icon
	: undefined;
---

<article class="info-card">
	{iconSrc && (
		<div class="info-card-icon-wrap">
			<img
				class="info-card-icon"
				src={iconSrc}
				alt={iconAlt || ""}
				loading="lazy"
			/>
		</div>
	)}

	<h3>{title}</h3>
	<p>{description}</p>
</article>

<style>
	.info-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--info-card-radius);
		min-height: var(--info-card-min-height);
		padding: var(--info-card-padding);
		position: relative;
		overflow: hidden;
		transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
		            box-shadow 0.3s ease,
		            border-color 0.3s ease;
	}

	.info-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: var(--info-card-top-line-height);
		background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-primary-soft) 100%);
		border-radius: var(--info-card-radius) var(--info-card-radius) 0 0;
		opacity: 0.6;
		transition: opacity 0.3s ease;
	}

	.info-card:hover {
		border-color: var(--color-border-strong);
		box-shadow: 0 8px 32px rgba(117, 62, 19, 0.11),
		            0 2px 8px rgba(117, 62, 19, 0.06);
		transform: translateY(-4px);
	}

	.info-card:hover::before {
		opacity: 1;
	}

	.info-card-icon-wrap {
		align-items: center;
		background: linear-gradient(135deg, var(--color-surface-warm) 0%, var(--color-surface-soft) 100%);
		border: 1px solid var(--color-border);
		border-radius: var(--schedule-card-radius);
		display: inline-flex;
		height: var(--info-card-icon-box-size);
		justify-content: center;
		margin-bottom: var(--info-card-icon-margin-bottom);
		width: var(--info-card-icon-box-size);
	}

	.info-card-icon {
		display: block;
		height: var(--info-card-icon-size);
		object-fit: contain;
		width: var(--info-card-icon-size);
	}

	h3 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: var(--info-card-title-size);
		font-weight: 600;
		line-height: 1.25;
		margin: 0 0 var(--info-card-title-margin-bottom);
	}

	p {
		color: var(--color-text-soft);
		font-size: var(--info-card-text-size);
		line-height: var(--paragraph-line-height);
		margin: 0;
	}

	@media (max-width: 860px) {
		.info-card {
			padding: var(--info-card-mobile-padding);
		}

		.info-card-icon-wrap {
			height: var(--info-card-icon-box-size-mobile);
			width: var(--info-card-icon-box-size-mobile);
		}

		.info-card-icon {
			height: var(--info-card-icon-size-mobile);
			width: var(--info-card-icon-size-mobile);
		}
	}
</style>
