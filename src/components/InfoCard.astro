---
interface Props {
	title: string;
	description: string;
	icon?: string;
	iconAlt?: string;
}

const { title, description, icon, iconAlt } = Astro.props;
---

<article class="info-card">
	{icon && (
		<img
			class="info-card-icon"
			src={icon}
			alt={iconAlt || ""}
			loading="lazy"
		/>
	)}

	<h3>{title}</h3>
	<p>{description}</p>
</article>

<style>
	.info-card {
		background: var(--color-surface-warm);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 28px;
	}

	.info-card-icon {
		width: 56px;
		height: 56px;
		object-fit: contain;
		display: block;
		margin-bottom: 18px;
	}

	h3 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: 1.4rem;
		margin: 0 0 14px;
	}

	p {
		color: var(--color-text-soft);
		font-size: 1.2rem;
		line-height: 1.75;
		margin: 0;
		font-weight: 500;
	}

	@media (max-width: 860px) {
		.info-card {
			padding: 24px;
		}

		.info-card-icon {
			width: 48px;
			height: 48px;
			margin-bottom: 16px;
		}
	}
</style>