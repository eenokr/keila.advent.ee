---
interface Props {
	pageUrl?: string;
	title?: string;
}

const { pageUrl, title = 'Keila Adventkoguduse Facebooki postitused' } = Astro.props;
const pluginUrl = pageUrl
	? `https://www.facebook.com/plugins/page.php?href=${encodeURIComponent(pageUrl)}&tabs=timeline&width=500&height=430&small_header=true&adapt_container_width=true&hide_cover=false&show_facepile=false`
	: undefined;
---

{pluginUrl && (
	<div class="facebook-feed">
		<div class="facebook-feed-inner">
			<iframe
				src={pluginUrl}
				title={title}
				width="500"
				height="430"
				style="border:none;overflow:hidden"
				scrolling="no"
				frameborder="0"
				allowfullscreen={true}
				allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
				loading="lazy"
			>
			</iframe>
		</div>
	</div>
)}

<style>
	.facebook-feed {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		box-shadow: var(--shadow-warm);
		width: 100%;
		max-width: 500px;
		overflow: hidden;
		box-sizing: border-box;
	}

	.facebook-feed-inner {
		width: 100%;
		max-width: 500px;
		margin: 0 auto;
		overflow: hidden;
	}

	.facebook-feed iframe {
		display: block;
		width: 100%;
		max-width: 500px;
		border: 0;
	}

	@media (max-width: 560px) {
		.facebook-feed {
			max-width: 100%;
		}

		.facebook-feed-inner {
			max-width: 100%;
		}

		.facebook-feed iframe {
			width: 100%;
			max-width: 100%;
		}
	}
</style>