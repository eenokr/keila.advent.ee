---
interface Props {
	pageUrl?: string;
	title?: string;
}

const { pageUrl, title = 'Keila Adventkoguduse Facebooki postitused' } = Astro.props;
const normalizedPageUrl = pageUrl
	? pageUrl.trim().replace(/\/+$/u, '') + '/'
	: undefined;
const pluginUrl = normalizedPageUrl
	? `https://www.facebook.com/plugins/page.php?href=${encodeURIComponent(normalizedPageUrl)}&tabs=timeline&width=500&height=700&small_header=true&adapt_container_width=true&hide_cover=false&show_facepile=false`
	: undefined;
---

{pluginUrl ? (
	<div class="facebook-feed">
		<iframe
			class="facebook-feed-frame"
			src={pluginUrl}
			title={title}
			width="500"
			height="700"
			style="border:none;overflow:hidden"
			scrolling="no"
			frameborder="0"
			allowfullscreen={true}
			allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
			loading="lazy"
		></iframe>
	</div>
) : (
	<div class="facebook-feed-empty">Facebooki voo URL puudub või on vale.</div>
)}

<style>
	.facebook-feed,
	.facebook-feed-empty {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		box-shadow: var(--shadow-warm);
		width: 100%;
		max-width: 500px;
		box-sizing: border-box;
		margin-left: auto;
		margin-right: auto;
	}

	.facebook-feed {
		overflow: hidden;
		padding: 1rem 0;
	}

	.facebook-feed-frame {
		width: 100%;
		max-width: 500px;
		height: 700px;
		border: 0;
		margin: 0 auto;
	}

	.facebook-feed-empty {
		padding: 1rem;
		text-align: center;
		color: var(--color-text-muted);
	}

	@media (max-width: 560px) {
		.facebook-feed,
		.facebook-feed-empty {
			max-width: 100%;
		}
	}
</style>