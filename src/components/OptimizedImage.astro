---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
	class?: string;
	widths?: number[];
	sizes?: string;
}

const {
	src,
	alt,
	caption,
	class: className,
	widths = [640, 960, 1200],
	sizes = '(max-width: 760px) calc(100vw - 40px), 760px',
} = Astro.props;
---

<figure class:list={['optimized-image', className]}>
	<Picture
		src={src}
		formats={['webp']}
		widths={widths}
		sizes={sizes}
		alt={alt}
		loading="lazy"
		quality={85}
	/>
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	.optimized-image {
		margin: 32px 0;
	}

	.optimized-image :global(picture),
	.optimized-image :global(img) {
		display: block;
		width: 100%;
	}

	.optimized-image :global(img) {
		border-radius: 8px;
		height: auto;
	}

	.optimized-image figcaption {
		color: var(--color-text-soft);
		font-size: 0.92rem;
		line-height: 1.5;
		margin-top: 10px;
		text-align: center;
	}
</style>
