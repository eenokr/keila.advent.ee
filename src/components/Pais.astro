---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import adventLogo from '../assets/branding/advent-logo.png';

const base = import.meta.env.BASE_URL;
const [siteEntry] = await getCollection('site');
const site = siteEntry.data;
const navItems = site.nav;
const titleLineOne = site.titleLine1;
const titleLineTwo = site.titleLine2;
const currentPath = Astro.url.pathname;
const imageModules = import.meta.glob<ImageMetadata>('../assets/pildid/*', {
	eager: true,
	import: 'default',
});
const logoAsset = site.logoImage === 'advent-logo.png' ? adventLogo : imageModules[`../assets/pildid/${site.logoImage}`];

function withBase(href: string) {
	if (href.startsWith('http')) return href;
	if (href.startsWith('#')) return currentPath === base ? href : `${base}${href}`;
	if (href === '/') return base;
	return `${base}${href.replace(/^\//, '')}`;
}

// Flatten nav items: regular items + children of group items
const flatNavItems: { label: string; navLabel: string; href: string }[] = [];
for (const item of navItems) {
	if (item.children) {
		for (const child of item.children) {
			flatNavItems.push({ label: child.label, navLabel: child.navLabel ?? child.label, href: child.href });
		}
	} else if (item.href) {
		flatNavItems.push({ label: item.label, navLabel: item.navLabel ?? item.label, href: item.href });
	}
}
---

<header class="header-main">
	<nav class="header-nav" aria-label="Põhinavigatsioon">
		<div class="logo-container">
			<a href={base} class="brand">
				{logoAsset && (
					<Image
						src={logoAsset}
						alt={site.logoAlt}
						width={96}
						height={96}
						class="brand-logo"
						loading="eager"
						decoding="async"
						quality={90}
					/>
				)}
				<span class="brand-title" aria-label={site.title}>
					<span class="brand-title-line">{titleLineOne}</span>
					<span class="brand-title-line">{titleLineTwo}</span>
				</span>
			</a>
		</div>

		<ul class="nav-menu" id="nav-menu" role="list">
			{flatNavItems.map((item, i) => (
				<li class="nav-item" data-nav-item data-nav-index={i}>
					<a href={withBase(item.href)} class="nav-link" title={item.label !== item.navLabel ? item.label : undefined}>
						{item.navLabel}
					</a>
				</li>
			))}

			<!-- Overflow item: shown when items don't fit -->
			<li class="nav-item nav-overflow-item" id="nav-overflow-item" hidden>
				<button class="nav-link nav-dropdown-toggle" id="nav-overflow-toggle" type="button" aria-expanded="false" aria-controls="nav-overflow-menu">
					{site.mobileMenuText}
					<svg class="dropdown-chevron" width="11" height="11" viewBox="0 0 12 12" aria-hidden="true" fill="none">
						<path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>
				<div class="dropdown-menu" id="nav-overflow-menu" role="menu">
					{flatNavItems.map((item, i) => (
						<a href={withBase(item.href)} class="dropdown-link" role="menuitem" data-overflow-link={i} hidden>
							{item.label}
						</a>
					))}
				</div>
			</li>
		</ul>

		<div class="header-actions">
			<button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu">
				<span class="mobile-menu-icon" aria-hidden="true">☰</span>
				<span class="mobile-menu-text">{site.mobileMenuText}</span>
			</button>
			<a href={withBase(site.headerCta.href)} class="header-cta">{site.headerCta.text}</a>
		</div>
	</nav>

	<div class="mobile-menu" id="mobile-menu" hidden>
		<ul>
			{navItems.map((item) => (
				item.children ? (
					<li class="mobile-nav-accordion">
						<button class="mobile-accordion-toggle" type="button" aria-expanded="false">
							{item.label}
							<svg class="mobile-accordion-chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true" fill="none">
								<path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</button>
						<ul class="mobile-accordion-children" hidden>
							{item.children.map((child) => (
								<li><a href={withBase(child.href)} class="mobile-nav-link mobile-nav-child">{child.label}</a></li>
							))}
						</ul>
					</li>
				) : (
					<li><a href={withBase(item.href!)} class="mobile-nav-link">{item.label}</a></li>
				)
			))}
		</ul>
	</div>
</header>

<aside class="advent-sidebar" aria-label="Seitsmenda Päeva Adventistide Keila Kogudus">
	<a href={base} class="sidebar-logo-link" tabindex="-1" aria-hidden="true">
		<Image
			src={adventLogo}
			alt=""
			width={280}
			height={280}
			class="sidebar-logo"
			loading="eager"
			decoding="async"
			quality={90}
		/>
	</a>
</aside>

<style>
	.header-main {
		background: var(--color-surface-soft);
		border-bottom: 1px solid var(--color-border);
		position: sticky;
		top: 0;
		z-index: 100;
		transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
	}

	.header-main.is-scrolled {
		background: rgba(255, 250, 244, 0.88);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom-color: rgba(235, 201, 161, 0.45);
		box-shadow: 0 2px 24px rgba(117, 62, 19, 0.09);
	}

	.header-nav {
		max-width: var(--header-max-width);
		margin: 0 auto;
		padding: 0 20px;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		min-height: var(--header-height);
		font-family: var(--font-body);
		column-gap: 16px;
	}

	.logo-container {
		justify-self: start;
		min-width: 0;
	}

	.brand {
		text-decoration: none;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 8px;
		height: 72px;
		line-height: 1;
	}

	.brand-logo {
		height: auto;
		max-height: var(--header-logo-height);
		width: auto;
		display: block;
		transform-origin: center;
		transition: transform 0.3s ease, opacity 0.3s ease, filter 0.3s ease;
	}

	.brand:hover .brand-logo,
	.brand:focus-visible .brand-logo,
	.brand:active .brand-logo {
		transform: scale(1.05) translateY(-2px);
		opacity: 0.95;
		filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.14));
	}

	.brand-title {
		color: var(--color-heading);
		display: flex;
		flex-direction: column;
		font-family: var(--font-body);
		font-size: var(--header-title-font-size);
		font-weight: 400;
		letter-spacing: 0.01em;
		line-height: 1.18;
		max-width: 170px;
		text-transform: uppercase;
		transition: transform 0.3s ease, opacity 0.3s ease, filter 0.3s ease, color 0.3s ease;
	}

	.brand-title-line {
		display: block;
	}

	.brand:hover .brand-title,
	.brand:focus-visible .brand-title,
	.brand:active .brand-title {
		transform: scale(1.05) translateY(-2px);
		opacity: 0.95;
		filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.14));
		color: var(--color-primary);
	}

	.nav-menu {
		display: flex;
		align-items: center;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 18px;
		justify-content: center;
		justify-self: stretch;
		min-width: 0;
		overflow-x: clip;
		overflow-y: visible;
	}

	.nav-item {
		position: relative;
		flex-shrink: 0;
	}

	/* Hide overflow items in the nav bar — JS controls this */
	.nav-item[hidden] {
		display: none;
	}

	.nav-overflow-item {
		flex-shrink: 0;
	}

	.nav-dropdown-toggle {
		align-items: center;
		background: none;
		border: none;
		color: var(--color-text);
		cursor: pointer;
		display: inline-flex;
		font-family: var(--font-body);
		font-size: var(--header-nav-font-size);
		font-weight: 400;
		gap: 4px;
		line-height: 1;
		margin: 0;
		padding: 8px 0;
		position: relative;
		text-transform: uppercase;
		vertical-align: middle;
		white-space: nowrap;
	}

	.nav-dropdown-toggle:hover {
		color: var(--color-primary);
	}

	.dropdown-chevron {
		flex-shrink: 0;
		transition: transform 0.22s ease;
	}

	.nav-dropdown-toggle[aria-expanded='true'] .dropdown-chevron {
		transform: rotate(180deg);
	}

	.dropdown-menu {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		box-shadow: 0 8px 36px rgba(117, 62, 19, 0.13), 0 2px 8px rgba(117, 62, 19, 0.07);
		left: 50%;
		min-width: 270px;
		opacity: 0;
		padding: 6px;
		pointer-events: none;
		position: absolute;
		top: calc(100% + 10px);
		transform: translateX(-50%) translateY(-6px);
		transition: opacity 0.2s ease, transform 0.2s ease;
		z-index: 200;
	}

	.nav-dropdown-toggle[aria-expanded='true'] + .dropdown-menu {
		opacity: 1;
		pointer-events: auto;
		transform: translateX(-50%) translateY(0);
	}

	.dropdown-link {
		border-radius: 8px;
		color: var(--color-text);
		display: block;
		font-size: 0.88rem;
		line-height: 1.35;
		padding: 10px 14px;
		text-decoration: none;
		transition: background 0.15s ease, color 0.15s ease;
		white-space: normal;
	}

	.dropdown-link[hidden] {
		display: none;
	}

	.dropdown-link:hover {
		background: var(--color-surface-warm);
		color: var(--color-primary);
	}

	.dropdown-link + .dropdown-link {
		margin-top: 2px;
	}

	.nav-link {
		position: relative;
		text-decoration: none;
		color: var(--color-text);
		font-size: var(--header-nav-font-size);
		font-weight: 400;
		text-transform: uppercase;
		transition: color 0.3s ease;
		padding: 8px 0;
		white-space: nowrap;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		width: 100%;
		height: 2px;
		background: var(--color-primary);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.3s ease;
	}

	.nav-link:hover {
		color: var(--color-primary);
	}

	.nav-link:hover::after {
		transform: scaleX(1);
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 8px;
		justify-self: end;
	}

	.mobile-menu-toggle {
		align-items: center;
		background: transparent;
		border: 1px solid var(--color-border);
		border-radius: 5px;
		color: var(--color-text);
		cursor: pointer;
		display: none;
		font-family: var(--font-body);
		font-size: 0.78rem;
		font-weight: 500;
		gap: 6px;
		min-height: 36px;
		padding: 0 10px;
	}

	.mobile-menu-toggle:hover,
	.mobile-menu-toggle[aria-expanded='true'] {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	.mobile-menu-icon {
		font-size: 1rem;
		line-height: 1;
	}

	.header-cta {
		display: inline-block;
		background: var(--color-primary);
		border: 2px solid var(--color-primary);
		border-radius: 5px;
		padding: 9px 14px;
		color: #ffffff;
		text-decoration: none;
		font-family: var(--font-body);
		font-weight: 400;
		font-size: var(--header-cta-font-size);
		transition: all 0.3s ease;
		white-space: nowrap;
	}

	.header-cta:hover {
		background: var(--color-primary-dark);
		border-color: var(--color-primary-dark);
	}

	.mobile-menu {
		background: var(--color-surface-soft);
		border-top: 1px solid var(--color-border);
		box-shadow: 0 18px 30px rgba(117, 62, 19, 0.1);
		padding: 0 14px 14px;
	}

	.mobile-menu[hidden] {
		display: none;
	}

	.mobile-menu > ul {
		display: grid;
		gap: 2px;
		list-style: none;
		margin: 0 auto;
		max-width: var(--header-max-width);
		padding: 0;
	}

	.mobile-nav-link {
		border-radius: 5px;
		color: var(--color-text);
		display: block;
		font-size: 0.92rem;
		padding: 12px 4px;
		text-decoration: none;
	}

	.mobile-nav-link:hover {
		color: var(--color-primary);
	}

	.mobile-accordion-toggle {
		align-items: center;
		background: none;
		border: none;
		border-radius: 5px;
		color: var(--color-text);
		cursor: pointer;
		display: flex;
		font-family: var(--font-body);
		font-size: 0.92rem;
		justify-content: space-between;
		padding: 12px 4px;
		text-decoration: none;
		width: 100%;
	}

	.mobile-accordion-toggle:hover {
		color: var(--color-primary);
	}

	.mobile-accordion-chevron {
		flex-shrink: 0;
		transition: transform 0.22s ease;
	}

	.mobile-accordion-toggle[aria-expanded='true'] .mobile-accordion-chevron {
		transform: rotate(180deg);
	}

	.mobile-accordion-children {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.mobile-accordion-children[hidden] {
		display: none;
	}

	.mobile-nav-child {
		color: var(--color-text-soft);
		font-size: 0.9rem;
		padding-left: 18px;
	}

	@media (max-width: 900px) {
		.header-nav {
			padding: 0 14px;
			min-height: 82px;
			column-gap: 10px;
		}

		.brand {
			gap: 7px;
			height: 66px;
		}

		.brand-logo {
			height: auto;
			max-height: 54px;
			width: auto;
		}

		.brand-title {
			font-size: 0.54rem;
			font-weight: 400;
			max-width: 120px;
		}

		.nav-menu {
			gap: 12px;
		}

		.nav-link {
			font-size: 0.82rem;
		}

		.header-cta {
			padding: 7px 10px;
			font-size: 0.72rem;
		}
	}

	@media (max-width: 520px) {
		.header-nav {
			grid-template-columns: auto auto;
			justify-content: space-between;
			min-height: 78px;
		}

		.nav-menu {
			display: none;
		}

		.mobile-menu-toggle {
			display: inline-flex;
		}

		.header-cta {
			padding: 8px 10px;
			font-size: 0.74rem;
		}
	}

	/* ── Parempoolne riba ────────────────────────────────────────────────────── */

	.advent-sidebar {
		background-color: var(--color-primary);
		bottom: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		padding-top: 18px;
		position: fixed;
		right: 0;
		top: 0;
		width: var(--sidebar-width);
		z-index: 90;
	}

	.sidebar-logo-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 78%;
		padding: 8px 0;
		text-decoration: none;
	}

	.sidebar-logo {
		filter: brightness(0) invert(1);
		width: 100%;
		height: auto;
	}
</style>

<script>
	// ── Priority Navigation ─────────────────────────────────────────────────────
	// On wide screens: show all nav items flat. When they don't fit,
	// move overflow items to a dropdown. Below 520px: use mobile burger instead.

	function initPriorityNav() {
		const navMenu = document.getElementById('nav-menu') as HTMLUListElement | null;
		const overflowItem = document.getElementById('nav-overflow-item') as HTMLLIElement | null;
		const overflowToggle = document.getElementById('nav-overflow-toggle') as HTMLButtonElement | null;
		const overflowMenu = document.getElementById('nav-overflow-menu') as HTMLElement | null;
		if (!navMenu || !overflowItem || !overflowToggle || !overflowMenu) return;

		// Non-null assertions — we've already guarded above
		const menu = navMenu!;
		const ovItem = overflowItem!;
		const ovToggle = overflowToggle!;
		const ovMenu = overflowMenu!;

		const allNavItems = Array.from(menu.querySelectorAll<HTMLElement>('[data-nav-item]'));
		const overflowLinks = Array.from(ovMenu.querySelectorAll<HTMLElement>('[data-overflow-link]'));
		const gap = 18;

		// Pre-measure natural widths of each item once (before any hiding)
		const itemWidths: number[] = [];
		let overflowBtnWidth = 0;

		function preMeasure() {
			allNavItems.forEach(el => el.removeAttribute('hidden'));
			ovItem.removeAttribute('hidden');
			overflowBtnWidth = ovItem.offsetWidth + gap;
			allNavItems.forEach(el => { itemWidths.push(el.offsetWidth); });
			ovItem.setAttribute('hidden', '');
		}

		function measure() {
			if (window.innerWidth <= 520) {
				allNavItems.forEach(el => el.removeAttribute('hidden'));
				ovItem.setAttribute('hidden', '');
				return;
			}

			const menuWidth = menu.offsetWidth;
			let used = 0;
			let firstHidden = -1;

			for (let i = 0; i < allNavItems.length; i++) {
				const w = itemWidths[i] ?? allNavItems[i].offsetWidth;
				const next = used + (i > 0 ? gap : 0) + w;
				const willNeedBtn = firstHidden >= 0 || i < allNavItems.length - 1;
				if (next + (willNeedBtn ? overflowBtnWidth : 0) > menuWidth && firstHidden < 0) {
					firstHidden = i;
				}
				used = next;
			}

			let anyHidden = false;
			allNavItems.forEach((el, i) => {
				const hide = firstHidden >= 0 && i >= firstHidden;
				el.toggleAttribute('hidden', hide);
				if (hide) anyHidden = true;
			});
			overflowLinks.forEach((link, i) => {
				link.toggleAttribute('hidden', firstHidden < 0 || i < firstHidden);
			});
			ovItem.toggleAttribute('hidden', !anyHidden);
		}

		preMeasure();
		measure();

		new ResizeObserver(() => measure()).observe(menu);

		ovToggle.addEventListener('click', (e) => {
			e.stopPropagation();
			const open = ovToggle.getAttribute('aria-expanded') === 'true';
			ovToggle.setAttribute('aria-expanded', String(!open));
		});
		document.addEventListener('click', () => ovToggle.setAttribute('aria-expanded', 'false'));
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') ovToggle.setAttribute('aria-expanded', 'false');
		});
	}

	// ── Mobile menu ─────────────────────────────────────────────────────────────
	const menuButton = document.querySelector<HTMLButtonElement>('.mobile-menu-toggle');
	const mobileMenu = document.querySelector<HTMLElement>('#mobile-menu');
	const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');

	if (menuButton && mobileMenu) {
		menuButton.addEventListener('click', () => {
			const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
			menuButton.setAttribute('aria-expanded', String(!isOpen));
			mobileMenu.hidden = isOpen;
		});
		mobileLinks.forEach((link) => {
			link.addEventListener('click', () => {
				menuButton.setAttribute('aria-expanded', 'false');
				mobileMenu.hidden = true;
			});
		});
	}

	// ── Mobile accordion ────────────────────────────────────────────────────────
	document.querySelectorAll<HTMLButtonElement>('.mobile-accordion-toggle').forEach((toggle) => {
		toggle.addEventListener('click', () => {
			const isOpen = toggle.getAttribute('aria-expanded') === 'true';
			const children = toggle.nextElementSibling as HTMLElement | null;
			toggle.setAttribute('aria-expanded', String(!isOpen));
			if (children) children.hidden = isOpen;
		});
	});

	// ── Scroll glassmorphism ────────────────────────────────────────────────────
	const header = document.querySelector<HTMLElement>('.header-main');
	const handleScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 24);
	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll();

	// ── Scroll-reveal ───────────────────────────────────────────────────────────
	if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		document.documentElement.classList.add('animations-supported');
		const revealObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
						revealObserver.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.06, rootMargin: '0px 0px -28px 0px' }
		);
		document.querySelectorAll('.scroll-reveal').forEach((el) => revealObserver.observe(el));
	}

	initPriorityNav();

	// ── Sidebar scroll animation ────────────────────────────────────────────────
	// As user scrolls down: sidebar orange → white, logo white → orange
	(function () {
		const sidebarEl = document.querySelector<HTMLElement>('.advent-sidebar');
		const logoEl = document.querySelector<HTMLImageElement>('.sidebar-logo');
		if (!sidebarEl || !logoEl) return;

		// Start: #c7661a, End: #fffaf4 (page background)
		const startR = 199, startG = 102, startB = 26;
		const endR   = 255, endG   = 250, endB   = 244;

		function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
		function clamp(v: number) { return Math.max(0, Math.min(1, v)); }

		function update() {
			const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
			const t = clamp(window.scrollY / maxScroll);

			const r = Math.round(lerp(startR, endR, t));
			const g = Math.round(lerp(startG, endG, t));
			const b = Math.round(lerp(startB, endB, t));
			sidebarEl.style.backgroundColor = `rgb(${r},${g},${b})`;

			// brightness(0) invert(1) = white, brightness(1) invert(0) = original color
			const bri = lerp(0, 1, t).toFixed(3);
			const inv = lerp(1, 0, t).toFixed(3);
			logoEl.style.filter = `brightness(${bri}) invert(${inv})`;
		}

		window.addEventListener('scroll', update, { passive: true });
		update();
	})();
</script>
