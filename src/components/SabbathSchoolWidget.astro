---
// SabbathSchoolWidget.astro
// Kuvab tänase hingamispäevakooli õppetüki Adventech iframe'ina.
// URL arvutatakse iga päev automaatselt – GitHub raw kaudu kvartali alguse saamiseks.
---

<section class="ss-section" id="oppetykk">
	<div class="ss-inner">
		<div class="ss-intro">
			<p class="ss-eyebrow">Hingamispäevakool</p>
			<h2 class="ss-heading">Tänase päeva õppetükk</h2>
		</div>

		<div class="ss-wrap" id="ss-widget" aria-live="polite">
			<!-- Laadimisskelett -->
			<div id="ss-loading" class="ss-loading" aria-label="Laadib õppetükki...">
				<div class="sk sk-head"></div>
				<div class="sk sk-line"></div>
				<div class="sk sk-line sk-med"></div>
				<div class="sk sk-line sk-short"></div>
				<div class="sk sk-line"></div>
				<div class="sk sk-line sk-med"></div>
			</div>

			<!-- Adventech iframe -->
			<iframe
				id="ss-frame"
				class="ss-frame"
				hidden
				title="Tänane hingamispäevakooli õppetükk"
				referrerpolicy="no-referrer"
				allow="fullscreen"
			></iframe>

			<!-- Viga / tagavaralink -->
			<div id="ss-fallback" class="ss-fallback" hidden>
				<p class="ss-fallback-msg">Õppetükki ei õnnestunud laadida.</p>
				<a
					id="ss-link"
					class="ss-cta"
					href="https://sabbath-school.adventech.io/et"
					target="_blank"
					rel="noopener noreferrer"
				>
					Ava tänane õppetükk
					<svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
						<path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>
		</div>
	</div>
</section>

<script>
(function () {
	const GITHUB = 'https://raw.githubusercontent.com/Adventech/sabbath-school-lessons/master/src/et';
	const APP = 'https://sabbath-school.adventech.io/et';

	const cache = new Map<string, string | null>();

	async function fetchRaw(url: string): Promise<string | null> {
		if (cache.has(url)) return cache.get(url)!;
		const ctrl = new AbortController();
		const timer = setTimeout(() => ctrl.abort(), 9000);
		try {
			const r = await fetch(url, { signal: ctrl.signal });
			const t = r.ok ? await r.text() : null;
			cache.set(url, t);
			return t;
		} catch {
			cache.set(url, null);
			return null;
		} finally {
			clearTimeout(timer);
		}
	}

	function parseYaml(text: string): Record<string, string> {
		const out: Record<string, string> = {};
		for (const line of text.split('\n')) {
			const i = line.indexOf(':');
			if (i < 1) continue;
			out[line.slice(0, i).trim()] = line.slice(i + 1).trim().replace(/^['"]|['"]$/g, '');
		}
		return out;
	}

	function parseDMY(s: string | undefined): Date | null {
		if (!s) return null;
		const p = s.trim().split('/').map(Number);
		if (p.length !== 3 || p.some(isNaN)) return null;
		return new Date(p[2], p[1] - 1, p[0]);
	}

	function pad(n: number) { return String(n).padStart(2, '0'); }

	function $(id: string) { return document.getElementById(id); }

	function showFallback(href?: string) {
		$('ss-loading')?.setAttribute('hidden', '');
		const fb = $('ss-fallback');
		if (fb) fb.removeAttribute('hidden');
		if (href) {
			const link = $('ss-link') as HTMLAnchorElement | null;
			if (link) link.href = href;
		}
	}

	async function init() {
		const now = new Date(); now.setHours(0, 0, 0, 0);
		const y = now.getFullYear();
		const q = Math.floor(now.getMonth() / 3) + 1;

		const candidates = [
			y + '-' + pad(q),
			q > 1 ? y + '-' + pad(q - 1) : (y - 1) + '-04',
			q < 4 ? y + '-' + pad(q + 1) : (y + 1) + '-01',
		];

		let url: string | null = null;

		for (const qId of candidates) {
			const qRaw = await fetchRaw(GITHUB + '/' + qId + '/info.yml');
			if (!qRaw) continue;
			const qMeta = parseYaml(qRaw);
			const qStart = parseDMY(qMeta.start_date);
			const qEnd = parseDMY(qMeta.end_date);
			if (!qStart || !qEnd || now < qStart || now > qEnd) continue;

			const lessonNum = Math.max(1, Math.min(13,
				Math.floor((now.getTime() - qStart.getTime()) / (86400000 * 7)) + 1
			));

			const lRaw = await fetchRaw(GITHUB + '/' + qId + '/' + pad(lessonNum) + '/info.yml');
			if (!lRaw) continue;
			const lMeta = parseYaml(lRaw);
			const lStart = parseDMY(lMeta.start_date);
			if (!lStart) continue;

			const dayIdx = Math.max(0, Math.min(6,
				Math.floor((now.getTime() - lStart.getTime()) / 86400000)
			));

			url = APP + '/' + qId + '/' + pad(lessonNum) + '/' + pad(dayIdx + 1);
			break;
		}

		if (!url) return showFallback();

		const frame = $('ss-frame') as HTMLIFrameElement | null;
		if (!frame) return showFallback(url);

		frame.addEventListener('load', () => {
			$('ss-loading')?.setAttribute('hidden', '');
			frame.removeAttribute('hidden');
		}, { once: true });

		// Kui 12 sekundi jooksul ei laadi, näita tagavaralinki
		const timeout = setTimeout(() => showFallback(url!), 12000);
		frame.addEventListener('load', () => clearTimeout(timeout), { once: true });

		frame.src = url;
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => void init().catch(() => showFallback()));
	} else {
		void init().catch(() => showFallback());
	}
})();
</script>

<style>
	.ss-section {
		background: var(--color-page);
		padding: 64px 20px 0;
	}

	.ss-inner {
		max-width: 1400px;
		margin: 0 auto;
	}

	.ss-intro {
		max-width: 700px;
		margin-bottom: 32px;
	}

	.ss-eyebrow {
		color: var(--color-accent);
		font-family: var(--font-heading);
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 14px;
		text-transform: uppercase;
	}

	.ss-heading {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 600;
		line-height: 1.1;
		margin: 0;
	}

	.ss-wrap {
		border-radius: 16px 16px 0 0;
		overflow: hidden;
		box-shadow: 0 -4px 32px rgba(117, 62, 19, 0.08);
	}

	/* Laadimisskelett */
	.ss-loading {
		background: var(--color-surface);
		display: flex;
		flex-direction: column;
		gap: 14px;
		padding: 48px 40px;
		min-height: 400px;
	}

	.sk {
		background: linear-gradient(
			90deg,
			var(--color-border) 0%,
			var(--color-surface-soft) 50%,
			var(--color-border) 100%
		);
		background-size: 200% 100%;
		animation: shimmer 1.5s ease-in-out infinite;
		border-radius: 6px;
		height: 18px;
	}

	@keyframes shimmer {
		0% { background-position: 200% 0; }
		100% { background-position: -200% 0; }
	}

	.sk-head { height: 36px; width: 60%; margin-bottom: 8px; }
	.sk-med  { width: 75%; }
	.sk-short { width: 45%; }

	/* iframe */
	.ss-frame {
		border: none;
		display: block;
		width: 100%;
		height: 100vh;
		min-height: 700px;
		max-height: 1100px;
	}

	/* Tagavaralink */
	.ss-fallback {
		background: var(--color-surface);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 18px;
		padding: 72px 24px;
		text-align: center;
	}

	.ss-fallback-msg {
		color: var(--color-text-soft);
		margin: 0;
	}

	.ss-cta {
		align-items: center;
		background: var(--color-primary);
		border-radius: 999px;
		color: #fff;
		display: inline-flex;
		font-family: var(--font-heading);
		font-size: 0.95rem;
		font-weight: 600;
		gap: 8px;
		padding: 12px 26px;
		text-decoration: none;
		transition: background 0.15s, transform 0.15s;
	}

	.ss-cta:hover {
		background: var(--color-primary-dark);
		color: #fff;
		transform: translateY(-1px);
	}

	@media (max-width: 640px) {
		.ss-section { padding: 48px 0 0; }
		.ss-intro { padding: 0 18px; margin-bottom: 24px; }
		.ss-wrap { border-radius: 0; }
		.ss-frame { height: 100svh; min-height: 500px; max-height: none; }
		.ss-loading { padding: 32px 20px; }
	}
</style>
