---
// SabbathSchoolWidget.astro
// URL arvutatakse koheselt matemaatiliselt – ühtegi API-päringut pole vaja.
// Q2 2026 algab 28. märtsil 2026 (referentspunkt). Iga kvartal = 91 päeva (13 nädalat).
---

<section class="ss-section" id="oppetykk">
	<div class="ss-inner">
		<div class="ss-intro">
			<p class="ss-eyebrow">Hingamispäevakool</p>
			<h2 class="ss-heading">Tänase päeva õppetükk</h2>
		</div>

		<div class="ss-wrap">
			<iframe
				id="ss-frame"
				class="ss-frame"
				src="about:blank"
				title="Tänane hingamispäevakooli õppetükk"
				referrerpolicy="no-referrer"
				allow="fullscreen"
			></iframe>
		</div>

		<div class="ss-footer">
			<a id="ss-link" class="ss-link" href="https://sabbath-school.adventech.io/et" target="_blank" rel="noopener noreferrer">
				Ava täisvaates
				<svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
					<path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</a>
			<span class="ss-credit">sabbath-school.adventech.io</span>
		</div>
	</div>
</section>

<script>
(function () {
	// Referentspunkt: Q2 2026 algab 28. märtsil 2026 (laupäev, kinnitatud)
	// Iga Adventech kvartal = täpselt 13 nädalat = 91 päeva
	const REF = new Date(2026, 2, 28); // märts on index 2
	const Q_DAYS = 91;
	const BASE_YEAR = 2026;
	const BASE_Q = 2;

	function pad(n: number): string { return String(n).padStart(2, '0'); }

	function computeUrl(): string {
		const now = new Date();
		now.setHours(0, 0, 0, 0);

		const diff = Math.floor((now.getTime() - REF.getTime()) / 86400000);
		const qOffset = Math.floor(diff / Q_DAYS);
		const diq = diff - qOffset * Q_DAYS; // päevad kvartalisiseselt (0–90)

		let qYear = BASE_YEAR;
		let qNum = BASE_Q + qOffset;
		while (qNum > 4) { qNum -= 4; qYear++; }
		while (qNum < 1) { qNum += 4; qYear--; }

		const quarterId = qYear + '-' + pad(qNum);
		const lessonNum = Math.max(1, Math.min(13, Math.floor(diq / 7) + 1));
		const dayNum = Math.max(1, Math.min(7, diq - (lessonNum - 1) * 7 + 1));

		return 'https://sabbath-school.adventech.io/et/' + quarterId + '/' + pad(lessonNum) + '/' + pad(dayNum);
	}

	const url = computeUrl();
	const frame = document.getElementById('ss-frame') as HTMLIFrameElement | null;
	const link = document.getElementById('ss-link') as HTMLAnchorElement | null;
	if (frame) frame.src = url;
	if (link) link.href = url;
})();
</script>

<style>
	.ss-section {
		background: var(--color-page);
		padding: 64px 20px 0;
	}

	.ss-inner {
		max-width: 1400px;
		margin: 0 auto;
	}

	.ss-intro {
		max-width: 700px;
		margin-bottom: 28px;
	}

	.ss-eyebrow {
		color: var(--color-accent);
		font-family: var(--font-heading);
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 12px;
		text-transform: uppercase;
	}

	.ss-heading {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 600;
		line-height: 1.1;
		margin: 0;
	}

	.ss-wrap {
		border-radius: 16px 16px 0 0;
		overflow: hidden;
		box-shadow: 0 -4px 32px rgba(117, 62, 19, 0.08);
	}

	.ss-frame {
		border: none;
		display: block;
		width: 100%;
		height: 92vh;
		min-height: 600px;
		max-height: 1200px;
	}

	.ss-footer {
		align-items: center;
		background: var(--color-surface);
		border-top: 1px solid var(--color-border);
		display: flex;
		gap: 16px;
		justify-content: space-between;
		padding: 14px 24px;
	}

	.ss-link {
		align-items: center;
		color: var(--color-primary);
		display: inline-flex;
		font-family: var(--font-heading);
		font-size: 0.9rem;
		font-weight: 600;
		gap: 6px;
		text-decoration: none;
		transition: color 0.15s, transform 0.15s;
	}

	.ss-link:hover {
		color: var(--color-primary-dark);
		transform: translateX(2px);
	}

	.ss-credit {
		color: var(--color-text-soft);
		font-size: 0.78rem;
	}

	@media (max-width: 640px) {
		.ss-section { padding: 48px 0 0; }
		.ss-intro { padding: 0 18px; }
		.ss-wrap { border-radius: 0; }
		.ss-frame { height: 100svh; min-height: 500px; max-height: none; }
		.ss-footer { padding: 12px 18px; }
	}
</style>
