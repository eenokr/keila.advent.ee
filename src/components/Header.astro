---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import adventLogo from '../assets/branding/advent-logo.png';

const base = import.meta.env.BASE_URL;
const [siteEntry] = await getCollection('site');
const site = siteEntry.data;
const navItems = site.nav;
const titleLineOne = site.titleLine1;
const titleLineTwo = site.titleLine2;
const imageModules = import.meta.glob<ImageMetadata>('../assets/images/*', {
	eager: true,
	import: 'default',
});
const logoAsset = site.logoImage === 'advent-logo.png' ? adventLogo : imageModules[`../assets/images/${site.logoImage}`];

function withBase(href: string) {
	if (href.startsWith('http')) return href;
	if (href.startsWith('#')) return `${base}${href}`;
	if (href === '/') return base;

	return `${base}${href.replace(/^\//, '')}`;
}
---

<header class="header-main">
	<nav class="header-nav">
		<div class="logo-container">
			<a href={base} class="brand">
				{logoAsset && (
					<Image
						src={logoAsset}
						alt={site.logoAlt}
						width={96}
						height={96}
						class="brand-logo"
						loading="eager"
						decoding="async"
						quality={90}
					/>
				)}
				<span class="brand-title" aria-label={site.title}>
					<span class="brand-title-line">{titleLineOne}</span>
					<span class="brand-title-line">{titleLineTwo}</span>
				</span>
			</a>
		</div>
		<ul class="nav-menu">
			{navItems.map((item) => (
				<li><a href={withBase(item.href)} class="nav-link">{item.label}</a></li>
			))}
		</ul>
		<div class="header-actions">
			<a href={withBase(site.headerCta.href)} class="header-cta">{site.headerCta.text}</a>
		</div>
	</nav>
</header>

<style>
	.header-main {
		background-color: var(--color-surface-soft);
		border-bottom: 1px solid var(--color-border);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.header-nav {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 16px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 116px;
		font-family: var(--font-body);
		gap: 14px;
	}

	.logo-container {
		flex-shrink: 0;
	}

	.brand {
		text-decoration: none;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 9px;
		height: 92px;
		line-height: 1;
	}

	.brand-logo {
		height: auto;
		max-height: 86px;
		width: auto;
		display: block;
	}

	.brand-title {
		color: var(--color-heading);
		display: flex;
		flex-direction: column;
		font-family: var(--font-body);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1.15;
		max-width: 190px;
		text-transform: uppercase;
	}

	.brand-title-line {
		display: block;
	}

	.nav-menu {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 22px;
		flex: 1;
		justify-content: center;
	}

	.nav-link {
		text-decoration: none;
		color: var(--color-text);
		font-size: 0.88rem;
		font-weight: 500;
		text-transform: uppercase;
		transition: color 0.3s ease;
		padding: 8px 0;
		border-bottom: 2px solid transparent;
	}

	.nav-link:hover {
		color: var(--color-primary);
		border-bottom-color: var(--color-primary);
	}

	.header-actions {
		flex-shrink: 0;
	}

	.header-cta {
		display: inline-block;
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-soft) 100%);
		border: 2px solid var(--color-primary);
		border-radius: 5px;
		padding: 11px 22px;
		color: #FFFFFF;
		text-decoration: none;
		font-family: var(--font-body);
		font-weight: 300;
		font-size: 0.88rem;
		transition: all 0.3s ease;
	}

	.header-cta:hover {
		background: var(--color-primary-dark);
		border-color: var(--color-primary-dark);
	}

	@media (max-width: 768px) {
		.header-nav {
			padding: 0 14px;
			min-height: 90px;
		}

		.brand {
			gap: 8px;
			height: 72px;
		}

		.brand-logo {
			height: auto;
			max-height: 66px;
			width: auto;
		}

		.brand-title {
			font-size: 0.6rem;
			font-weight: 500;
			max-width: 138px;
		}

		.nav-menu {
			display: none;
		}

		.header-cta {
			padding: 9px 14px;
			font-size: 0.82rem;
		}
	}
</style>
