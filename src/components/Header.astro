---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import adventLogo from '../assets/branding/advent-logo.png';

const base = import.meta.env.BASE_URL;
const [siteEntry] = await getCollection('site');
const site = siteEntry.data;
const navItems = site.nav;
const titleLineOne = site.titleLine1;
const titleLineTwo = site.titleLine2;
const imageModules = import.meta.glob<ImageMetadata>('../assets/images/*', {
	eager: true,
	import: 'default',
});
const logoAsset = site.logoImage === 'advent-logo.png' ? adventLogo : imageModules[`../assets/images/${site.logoImage}`];

function withBase(href: string) {
	if (href.startsWith('http')) return href;
	if (href.startsWith('#')) return `${base}${href}`;
	if (href === '/') return base;

	return `${base}${href.replace(/^\//, '')}`;
}
---

<header class="header-main">
	<nav class="header-nav">
		<div class="logo-container">
			<a href={base} class="brand">
				{logoAsset && (
					<Image
						src={logoAsset}
						alt={site.logoAlt}
						width={96}
						height={96}
						class="brand-logo"
						loading="eager"
						decoding="async"
						quality={90}
					/>
				)}
				<span class="brand-title" aria-label={site.title}>
					<span class="brand-title-line">{titleLineOne}</span>
					<span class="brand-title-line">{titleLineTwo}</span>
				</span>
			</a>
		</div>

		<ul class="nav-menu">
			{navItems.map((item) => (
				<li><a href={withBase(item.href)} class="nav-link">{item.label}</a></li>
			))}
		</ul>

		<div class="header-actions">
			<button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu">
				<span class="mobile-menu-icon" aria-hidden="true">☰</span>
				<span class="mobile-menu-text">Menüü</span>
			</button>
			<a href={withBase(site.headerCta.href)} class="header-cta">{site.headerCta.text}</a>
		</div>
	</nav>

	<div class="mobile-menu" id="mobile-menu" hidden>
		<ul>
			{navItems.map((item) => (
				<li><a href={withBase(item.href)} class="mobile-nav-link">{item.label}</a></li>
			))}
		</ul>
	</div>
</header>

<style>
	.header-main {
		background-color: var(--color-surface-soft);
		border-bottom: 1px solid var(--color-border);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.header-nav {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 20px;
		display: grid;
		grid-template-columns: minmax(220px, 1fr) auto minmax(160px, 1fr);
		align-items: center;
		min-height: 88px;
		font-family: var(--font-body);
		column-gap: 16px;
	}

	.logo-container {
		justify-self: start;
		min-width: 0;
	}

	.brand {
		text-decoration: none;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 8px;
		height: 72px;
		line-height: 1;
	}

	.brand-logo {
		height: auto;
		max-height: 64px;
		width: auto;
		display: block;
	}

	.brand-title {
		color: var(--color-heading);
		display: flex;
		flex-direction: column;
		font-family: var(--font-body);
		font-size: 0.68rem;
		font-weight: 400;
		letter-spacing: 0.01em;
		line-height: 1.18;
		max-width: 170px;
		text-transform: uppercase;
	}

	.brand-title-line {
		display: block;
	}

	.nav-menu {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 18px;
		justify-content: center;
		justify-self: center;
		min-width: 0;
	}

	.nav-link {
		text-decoration: none;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 400;
		text-transform: uppercase;
		transition: color 0.3s ease;
		padding: 8px 0;
		border-bottom: 2px solid transparent;
		white-space: nowrap;
	}

	.nav-link:hover {
		color: var(--color-primary);
		border-bottom-color: var(--color-primary);
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 8px;
		justify-self: end;
	}

	.mobile-menu-toggle {
		align-items: center;
		background: transparent;
		border: 1px solid var(--color-border);
		border-radius: 5px;
		color: var(--color-text);
		cursor: pointer;
		display: none;
		font-family: var(--font-body);
		font-size: 0.78rem;
		font-weight: 500;
		gap: 6px;
		min-height: 36px;
		padding: 0 10px;
	}

	.mobile-menu-toggle:hover,
	.mobile-menu-toggle[aria-expanded='true'] {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	.mobile-menu-icon {
		font-size: 1rem;
		line-height: 1;
	}

	.header-cta {
		display: inline-block;
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-soft) 100%);
		border: 2px solid var(--color-primary);
		border-radius: 5px;
		padding: 9px 14px;
		color: #ffffff;
		text-decoration: none;
		font-family: var(--font-body);
		font-weight: 400;
		font-size: 0.82rem;
		transition: all 0.3s ease;
		white-space: nowrap;
	}

	.header-cta:hover {
		background: var(--color-primary-dark);
		border-color: var(--color-primary-dark);
	}

	.mobile-menu {
		background: var(--color-surface-soft);
		border-top: 1px solid var(--color-border);
		box-shadow: 0 18px 30px rgba(117, 62, 19, 0.1);
		padding: 0 14px 14px;
	}

	.mobile-menu[hidden] {
		display: none;
	}

	.mobile-menu ul {
		display: grid;
		gap: 2px;
		list-style: none;
		margin: 0 auto;
		max-width: 1200px;
		padding: 0;
	}

	.mobile-nav-link {
		border-radius: 5px;
		color: var(--color-text);
		display: block;
		font-size: 0.92rem;
		padding: 12px 4px;
		text-decoration: none;
	}

	.mobile-nav-link:hover {
		color: var(--color-primary);
	}

	@media (max-width: 900px) {
		.header-nav {
			padding: 0 14px;
			grid-template-columns: minmax(172px, 1fr) auto minmax(118px, 1fr);
			min-height: 82px;
			column-gap: 10px;
		}

		.brand {
			gap: 7px;
			height: 66px;
		}

		.brand-logo {
			height: auto;
			max-height: 54px;
			width: auto;
		}

		.brand-title {
			font-size: 0.54rem;
			font-weight: 400;
			max-width: 120px;
		}

		.nav-menu {
			gap: 12px;
		}

		.nav-link {
			font-size: 0.82rem;
		}

		.header-cta {
			padding: 7px 10px;
			font-size: 0.72rem;
		}
	}

	@media (max-width: 620px) {
		.header-nav {
			grid-template-columns: auto auto;
			justify-content: space-between;
			min-height: 78px;
		}

		.brand-logo {
			max-height: 52px;
		}

		.brand-title {
			font-size: 0.54rem;
			max-width: 120px;
		}

		.nav-menu {
			display: none;
		}

		.mobile-menu-toggle {
			display: inline-flex;
		}

		.header-cta {
			padding: 8px 10px;
			font-size: 0.74rem;
		}
	}

	@media (max-width: 20px) {
		.header-nav {
			padding: 0 10px;
		}

		.brand-logo {
			max-height: 48px;
		}

		.brand-title {
			font-size: 0.5rem;
			max-width: 110px;
		}

		.header-cta {
			padding: 7px 9px;
			font-size: 0.7rem;
		}
	}
</style>

<script>
	const menuButton = document.querySelector<HTMLButtonElement>('.mobile-menu-toggle');
	const mobileMenu = document.querySelector<HTMLElement>('#mobile-menu');
	const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');

	if (menuButton && mobileMenu) {
		menuButton.addEventListener('click', () => {
			const isOpen = menuButton.getAttribute('aria-expanded') === 'true';

			menuButton.setAttribute('aria-expanded', String(!isOpen));
			mobileMenu.hidden = isOpen;
		});

		mobileLinks.forEach((link) => {
			link.addEventListener('click', () => {
				menuButton.setAttribute('aria-expanded', 'false');
				mobileMenu.hidden = true;
			});
		});
	}
</script>
