---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="footer-main">
	<div class="footer-content">
		<div class="footer-logo-section">
			<h3 class="footer-title">{SITE_TITLE}</h3>
		</div>

		<div class="footer-info">
			<p class="footer-text">
				Seitsmenda Päeva Adventistide Keila kogudus
			</p>
			<p class="footer-contact">
				Keila, Harjumaa | info@keila.ee
			</p>
		</div>

		<div class="footer-socials">
			<a href="https://facebook.com" target="_blank" aria-label="Facebook">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
					<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
				</svg>
			</a>
			<a href="https://instagram.com" target="_blank" aria-label="Instagram">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
					<path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 4a4 4 0 110 8 4 4 0 010-8zm6 2a1 1 0 110-2 1 1 0 010 2z"/>
				</svg>
			</a>
			<a href="https://youtube.com" target="_blank" aria-label="YouTube">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
					<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
				</svg>
			</a>
		</div>
	</div>

	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} {SITE_TITLE}. Kõik õigused reserveeritud.</p>
	</div>
</footer>

<style>
	.footer-main {
		background: linear-gradient(135deg, #f1f1f0 0%, #ffffff 100%);
		border-top: 1px solid #e0e0e0;
		padding: 60px 20px 40px;
		font-family: var(--font-body);
	}

	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 60px;
		margin-bottom: 40px;
		align-items: start;
	}

	.footer-logo-section {
		text-align: left;
	}

	.footer-title {
		font-size: 1.3rem;
		font-weight: 600;
		margin: 0 0 15px;
		color: #333;
	}

	.footer-info {
		text-align: center;
	}

	.footer-text,
	.footer-contact {
		font-size: 0.95rem;
		line-height: 1.6;
		margin: 0 0 10px;
		color: #555;
	}

	.footer-contact {
		font-weight: 500;
	}

	.footer-socials {
		display: flex;
		justify-content: flex-end;
		gap: 25px;
	}

	.footer-socials a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		color: #666;
		text-decoration: none;
		transition: color 0.3s ease, transform 0.3s ease;
	}

	.footer-socials a:hover {
		color: #333;
		transform: translateY(-3px);
	}

	.footer-bottom {
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 30px;
		border-top: 1px solid #e0e0e0;
		text-align: center;
	}

	.footer-bottom p {
		font-size: 0.85rem;
		color: #888;
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer-main {
			padding: 40px 20px 30px;
		}

		.footer-content {
			grid-template-columns: 1fr;
			gap: 30px;
			margin-bottom: 30px;
		}

		.footer-logo-section,
		.footer-info {
			text-align: center;
		}

		.footer-socials {
			justify-content: center;
		}
	}
</style>
