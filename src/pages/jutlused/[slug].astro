---
import { getCollection, render } from 'astro:content';
import PeaMeta from '../../components/PeaMeta.astro';
import Jalus from '../../components/Jalus.astro';
import Pais from '../../components/Pais.astro';

export async function getStaticPaths() {
	const sermons = await getCollection('sermons', ({ data }) => !data.draft);

	return sermons.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const [siteEntry] = await getCollection('site');
const site = siteEntry.data;
---

<html lang="et">
	<head>
		<PeaMeta
			title={`${entry.data.title} | ${site.title}`}
			description={entry.data.description ?? entry.data.title}
			siteTitle={site.title}
		/>
	</head>
	<body>
		<Pais />
		<main class="sermon-page">
			<article class="sermon-wrapper scroll-reveal">
				<p class="eyebrow">{entry.data.category}</p>
				<h1>{entry.data.title}</h1>
				{entry.data.description && <p class="sermon-description">{entry.data.description}</p>}
				{entry.data.audioUrl && (
					<audio controls src={entry.data.audioUrl}>
						Sinu brauser ei toeta audio esitust.
					</audio>
				)}
				<div class="sermon-content">
					<Content />
				</div>
			</article>
		</main>
		<Jalus />
	</body>
</html>

<style>
	.sermon-page {
		background: var(--color-page);
		padding: var(--sermon-page-padding-y) var(--section-padding-x);
	}

	.sermon-wrapper {
		max-width: var(--article-content-width);
		margin: 0 auto;
	}

	.eyebrow {
		color: var(--color-accent);
		font-family: var(--font-heading);
		font-size: var(--eyebrow-font-size);
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 16px;
		text-transform: uppercase;
	}

	h1 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: var(--sermon-title-size);
		line-height: 1.08;
		margin: 0;
	}

	audio {
		margin: 8px 0 28px;
		width: 100%;
	}

	.sermon-description,
	.sermon-content {
		color: var(--color-text-soft);
		font-size: var(--sermon-text-size);
		line-height: var(--paragraph-line-height);
	}

	.sermon-description {
		margin: 24px 0 28px;
	}

	.sermon-content :global(p) {
		margin: 0 0 20px;
	}
</style>
