---
import { IsPreviewing, getContent } from '@builder.io/sdk';

// Küsime sisu Builder.io-st lehe "page" mudelist ja teelt "/"
const content = await getContent({
  model: 'page',
  apiKey: 'd30ca60586cd42f4827fe377a484d056',
  userAttributes: {
    urlPath: '/'
  }
});
---

<html lang="et">
  <head>
    <title>Keila SDA Kogudus</title>
  </head>
  <body>
    {content ? (
      <div data-builder-component="page" data-builder-content-id={content.id}>
        {content.data?.blocks?.map((block: any) => (
          // See rida renderdab Builder.io visuaalsed blokid
          <div set:html={block.html} />
        ))}
      </div>
    ) : (
      <p>Lehte ei leitud või sisu puudub. Loo sisu Builder.io-s!</p>
    )}
  </html>