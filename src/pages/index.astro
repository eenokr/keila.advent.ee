---
import { getCollection } from 'astro:content';
import kodukaGalerii from '../data/koduka-galerii.json';
import kodukaTeated from '../data/koduka-teated.json';
import kirikuPilt from '../assets/branding/kiriku-pilt.jpg';
import uheskoosStuduioPilt from '../assets/branding/uheskoos-stuudio.jpg';
import PeaMeta from '../components/PeaMeta.astro';
import Jalus from '../components/Jalus.astro';
import Pais from '../components/Pais.astro';
import HingamispaevakooliVidin from '../components/HingamispaevakooliVidin.astro';
import HeroSektsioon from '../components/sections/HeroSektsioon.astro';
import KogunemisedSektsioon from '../components/sections/KogunemisedSektsioon.astro';
import MeistSektsioon from '../components/sections/MeistSektsioon.astro';
import FacebookiSektsioon from '../components/sections/FacebookiSektsioon.astro';
import AudioSektsioon from '../components/sections/AudioSektsioon.astro';
import KursusSektsioon from '../components/sections/KursusSektsioon.astro';
import KontaktSektsioon from '../components/sections/KontaktSektsioon.astro';
import { ADVENT_AUDIO_SOURCES, getAdventAudioItems } from '../lib/adventAudio';
import { getServiceScheduleItems } from '../lib/serviceSchedule';

const SERVICE_SCHEDULE_CSV_URL =
	'https://docs.google.com/spreadsheets/d/e/2PACX-1vTOmThNzJymlMrI5PiXxN5jcQTAotZvXrbYCZwDWQ8s2fqvbOckV6-XjCFkyUulLYUUl0HOqpyYIxrO/pub?gid=1165865253&single=true&output=csv';

const iconModules = import.meta.glob<string>('../assets/icons/*', {
	eager: true,
	import: 'default',
	query: '?url',
});

const koduleheEntries = await getCollection('koduleht');
const [siteEntry] = await getCollection('site');
const [contact] = await getCollection('contact');
const site = siteEntry.data;
const koduleht = Object.fromEntries(koduleheEntries.map((entry) => [entry.id, entry.data]));
const orderedKoduleheEntries = koduleheEntries.sort((a, b) => a.data.order - b.data.order);

const hero = koduleht.avaleht;
const services = koduleht.kogunemised;
const about = koduleht.meist;
const facebook = koduleht['facebooki-uudised'];
const audio = koduleht['jutlused-ja-raadiosaated'];
const course = koduleht.veebikoolitus;
const contactInfo = contact.data;
const visibleContactItems = contactInfo.contactItems.filter((item) => item.value.trim().length > 0);
const serviceScheduleActivities = services.scheduleActivities ?? [
	{
		key: 'jutlus',
		positiveText: 'Jutlus toimub',
		icon: 'jumalateenistus1.svg',
		iconAlt: 'Jutlus',
	},
	{
		key: 'piiblitund',
		positiveText: 'Piiblitund toimub',
		icon: 'bible1.svg',
		iconAlt: 'Piiblitund',
	},
	{
		key: 'lasteTundRl',
		positiveText: 'Lastetund toimub',
		icon: 'lastetund.svg',
		iconAlt: 'Lastetund',
	},
	{
		key: 'soomine',
		positiveText: 'Söömine toimub',
		icon: 'uhine-soomine.webp',
		iconAlt: 'Söömine',
	},
	{
		key: 'osasaamine',
		positiveText: 'Osasaamine toimub',
		icon: 'osasaamise.svg',
		iconAlt: 'Osasaamine',
	},
] as const;

function getIcon(filename?: string) {
	if (!filename) return undefined;
	if (filename.startsWith('http') || filename.startsWith('data:')) return filename;
	return iconModules[`../assets/icons/${filename.replace(/^\/?(images\/icons\/)?/, '')}`];
}

interface DriveImage {
	id: string; name: string; alt: string; modifiedTime: string;
	width: number; height: number;
	variants: { w: number; src: string }[];
}

function driveSlide(img: DriveImage) {
	return {
		src: img.variants.at(-1)?.src ?? '',
		srcset: img.variants.map((v) => `${v.src} ${v.w}w`).join(', '),
		width: img.width,
		height: img.height,
		alt: img.alt,
	};
}

const communitySlides = (kodukaGalerii as DriveImage[]).map(driveSlide);
const heroSlides = (kodukaTeated as DriveImage[]).length > 0
	? (kodukaTeated as DriveImage[]).map(driveSlide)
	: [{ image: kirikuPilt, alt: hero.imageAlt ?? 'Keila adventkoguduse hoone' }];
const [serviceScheduleItems, uheskoosAudioItems, sermonAudioItems] = await Promise.all([
	getServiceScheduleItems(SERVICE_SCHEDULE_CSV_URL, 4),
	getAdventAudioItems(ADVENT_AUDIO_SOURCES.uheskoos, 4),
	getAdventAudioItems(ADVENT_AUDIO_SOURCES.sermons, 4),
]);
const audioItemsByKey = {
	uheskoos: uheskoosAudioItems,
	sermons: sermonAudioItems,
};
const adventAudioBlocks = (audio.audioSources ?? [])
	.map((source) => ({
		...source,
		imageUrl: undefined as string | undefined,
		blockImage: source.key === 'uheskoos' ? uheskoosStuduioPilt : null,
		items: audioItemsByKey[source.key as keyof typeof audioItemsByKey],
	}))
	.filter((block) => block.items.length > 0);
---

<html lang="et">
	<head>
		<PeaMeta title={site.title} description={site.description} siteTitle={site.title} image={kirikuPilt} imageAlt={hero.imageAlt} />
	</head>
	<body>
		<Pais />
		<main>
			{orderedKoduleheEntries.map((entry) => (
				<>
					{entry.id === 'avaleht' && (
						<HeroSektsioon hero={hero} heroSlides={heroSlides} />
					)}
					{entry.id === 'kogunemised' && (
						<KogunemisedSektsioon
							services={services}
							serviceScheduleItems={serviceScheduleItems}
							serviceScheduleActivities={serviceScheduleActivities}
							getIcon={getIcon}
						/>
					)}
					{entry.id === 'meist' && (
						<MeistSektsioon about={about} communitySlides={communitySlides} />
					)}
					{entry.id === 'facebooki-uudised' && (
						<FacebookiSektsioon facebook={{ ...facebook, pageUrl: facebook.pageUrl }} />
					)}
					{entry.id === 'jutlused-ja-raadiosaated' && (
						<AudioSektsioon audio={audio} adventAudioBlocks={adventAudioBlocks} />
					)}
					{entry.id === 'veebikoolitus' && (
						<KursusSektsioon course={course} />
					)}
					{entry.id === 'oppetuki-app' && (
						<HingamispaevakooliVidin />
					)}
				</>
			))}

			<KontaktSektsioon contactInfo={contactInfo} visibleContactItems={visibleContactItems} />
		</main>
		<Jalus />
	</body>
</html>
