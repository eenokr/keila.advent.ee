---
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import GaleriiKarussell from '../components/GaleriiKarussell.astro';
import PeaMeta from '../components/PeaMeta.astro';
import TegevusNupp from '../components/TegevusNupp.astro';
import FacebookiVoog from '../components/FacebookiVoog.astro';
import Jalus from '../components/Jalus.astro';
import Pais from '../components/Pais.astro';
import Infokaart from '../components/Infokaart.astro';
import SektsiooniPealkiri from '../components/SektsiooniPealkiri.astro';
import HingamispaevakooliVidin from '../components/HingamispaevakooliVidin.astro';
import { ADVENT_AUDIO_SOURCES, getAdventAudioItems } from '../lib/adventAudio';
import { getServiceScheduleItems } from '../lib/serviceSchedule';

const SERVICE_SCHEDULE_CSV_URL =
	'https://docs.google.com/spreadsheets/d/e/2PACX-1vTOmThNzJymlMrI5PiXxN5jcQTAotZvXrbYCZwDWQ8s2fqvbOckV6-XjCFkyUulLYUUl0HOqpyYIxrO/pub?gid=1165865253&single=true&output=csv';

const imageModules = import.meta.glob<ImageMetadata>('../assets/pildid/*', {
	eager: true,
	import: 'default',
});
const galleryImageModules = import.meta.glob<ImageMetadata>('../assets/teated/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}', {
	eager: true,
	import: 'default',
});
const iconModules = import.meta.glob<string>('../assets/icons/*', {
	eager: true,
	import: 'default',
	query: '?url',
});

const koduleheEntries = await getCollection('koduleht');
const [siteEntry] = await getCollection('site');
const [contact] = await getCollection('contact');
const site = siteEntry.data;
const koduleht = Object.fromEntries(koduleheEntries.map((entry) => [entry.id, entry.data]));
const orderedKoduleheEntries = koduleheEntries.sort((a, b) => a.data.order - b.data.order);

const hero = koduleht.avaleht;
const services = koduleht.kogunemised;
const about = koduleht.meist;
const facebook = koduleht['facebooki-uudised'];
const audio = koduleht['jutlused-ja-raadiosaated'];
const course = koduleht.veebikoolitus;
const contactInfo = contact.data;
const visibleContactItems = contactInfo.contactItems.filter((item) => item.value.trim().length > 0);
const serviceScheduleActivities = services.scheduleActivities ?? [
	{
		key: 'jutlus',
		positiveText: 'Jutlus toimub',
		icon: 'jumalateenistus1.svg',
		iconAlt: 'Jutlus',
	},
	{
		key: 'piiblitund',
		positiveText: 'Piiblitund toimub',
		icon: 'bible1.svg',
		iconAlt: 'Piiblitund',
	},
	{
		key: 'lasteTundRl',
		positiveText: 'Lastetund toimub',
		icon: 'lastetund.svg',
		iconAlt: 'Lastetund',
	},
	{
		key: 'soomine',
		positiveText: 'Söömine toimub',
		icon: 'uhine-soomine.webp',
		iconAlt: 'Söömine',
	},
	{
		key: 'osasaamine',
		positiveText: 'Osasaamine toimub',
		icon: 'osasaamise.svg',
		iconAlt: 'Osasaamine',
	},
] as const;

function getImage(filename?: string) {
	if (!filename) return undefined;

	return imageModules[`../assets/pildid/${filename}`];
}

function getIcon(filename?: string) {
	if (!filename) return undefined;
	if (filename.startsWith('http') || filename.startsWith('data:')) return filename;

	return iconModules[`../assets/icons/${filename.replace(/^\/?(images\/icons\/)?/, '')}`];
}

function getGalleryAlt(path: string) {
	const filename = path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? 'teade';
	const title = filename.replace(/[-_]+/g, ' ').trim();

	return title ? `Koguduse teade: ${title}` : 'Koguduse teade';
}

function getCommunityAlt(path: string) {
	const filename = path.split('/').pop() ?? '';

	if (filename === about.image) return about.imageAlt ?? 'Koguduse pilt';
	if (filename === hero.image) return hero.imageAlt ?? 'Koguduse pilt';
	if (filename === 'stuudio.jpeg') return 'Koguduse stuudio ja salvestusruum';

	const title = filename.replace(/\.[^.]+$/, '').replace(/[-_]+/g, ' ').trim();

	return title ? `Koguduse pilt: ${title}` : 'Koguduse pilt';
}

const heroAsset = getImage(hero.image);
const gallerySlides = Object.entries(galleryImageModules)
	.sort(([pathA], [pathB]) => pathA.localeCompare(pathB, 'et'))
	.map(([path, image]) => ({
		image,
		alt: getGalleryAlt(path),
	}));
const communitySlides = Object.entries(imageModules)
	.sort(([pathA], [pathB]) => {
		const aboutPath = `../assets/pildid/${about.image}`;
		if (pathA === aboutPath) return -1;
		if (pathB === aboutPath) return 1;

		return pathA.localeCompare(pathB, 'et');
	})
	.map(([path, image]) => ({
		image,
		alt: getCommunityAlt(path),
	}));
const heroSlides = gallerySlides.length > 0
	? gallerySlides
	: heroAsset
		? [{ image: heroAsset, alt: hero.imageAlt ?? 'Keila adventkoguduse teade' }]
		: [];
const facebookPageUrl = facebook.pageUrl;
const [serviceScheduleItems, uheskoosAudioItems, sermonAudioItems] = await Promise.all([
	getServiceScheduleItems(SERVICE_SCHEDULE_CSV_URL, 4),
	getAdventAudioItems(ADVENT_AUDIO_SOURCES.uheskoos, 4),
	getAdventAudioItems(ADVENT_AUDIO_SOURCES.sermons, 4),
]);
const audioItemsByKey = {
	uheskoos: uheskoosAudioItems,
	sermons: sermonAudioItems,
};
const adventAudioBlocks = (audio.audioSources ?? [])
	.map((source) => ({
		...source,
		imageUrl: getImage(source.image)?.src,
		items: audioItemsByKey[source.key],
	}))
	.filter((block) => block.items.length > 0);
---

<html lang="et">
	<head>
		<PeaMeta title={site.title} description={site.description} siteTitle={site.title} image={heroAsset} />
	</head>
	<body>
		<Pais />
		<main class="page-wrapper">
			{orderedKoduleheEntries.map((entry) => (
				<>
					<!-- Sisu: src/content/koduleht/avaleht.md -->
					{entry.id === 'avaleht' && (
						<section class="hero-section" id="home">
							<div class="hero-content">
								<div class="hero-copy scroll-reveal">
									<h1>{hero.title}</h1>
									<p class="hero-intro">{hero.description}</p>
									<div class="hero-actions">
										{hero.buttons?.map((button) => (
											<TegevusNupp {...button} />
										))}
									</div>
								</div>
								<div class="scroll-reveal hero-carousel-wrap" style="--reveal-delay: 120ms">
									<GaleriiKarussell
										slides={heroSlides}
										intervalMs={6000}
										controlsLabel="Teadete valik"
										dotLabel="Näita teadet"
									/>
								</div>
							</div>
						</section>
					)}

					<!-- Sisu: src/content/koduleht/kogunemised.md -->
					{entry.id === 'kogunemised' && (
						<section class="info-section" id="services">
							<div class="section-inner">
								<div class="scroll-reveal">
									<SektsiooniPealkiri eyebrow={services.eyebrow} title={services.title} description={services.description} />
								</div>
								{services.cards && services.cards.length > 0 && (
									<div class="info-grid stagger">
										{services.cards.map((card) => (
											<div class="scroll-reveal">
												<Infokaart {...card} />
											</div>
										))}
									</div>
								)}
								{serviceScheduleItems.length > 0 && (
									<div class="service-schedule scroll-reveal" style="--reveal-delay: 80ms">
										<div class="service-schedule-grid stagger">
											{serviceScheduleItems.map((item) => (
												<article
													class:list={[
														'service-schedule-card',
														!serviceScheduleActivities.some((activity) => item[activity.key]) && 'is-empty',
													]}
												>
													<h4>{item.date}</h4>
													{serviceScheduleActivities.some((activity) => item[activity.key]) ? (
														<ul class="service-schedule-list">
															{serviceScheduleActivities
																.filter((activity) => item[activity.key])
																.map((activity) => {
																	const activityIcon = getIcon(activity.icon);

																	return (
																		<li>
																			{activityIcon && <img src={activityIcon} alt={activity.iconAlt ?? ''} loading="lazy" />}
																			<span>{activity.positiveText}</span>
																		</li>
																	);
																})}
														</ul>
													) : (
														<div class="service-schedule-empty" aria-label="Sel päeval tegevusi ei toimu">
															<img class="schedule-lock" src={getIcon('lukk.svg')} alt="" loading="lazy" />
														</div>
													)}
												</article>
											))}
										</div>
									</div>
								)}
							</div>
						</section>
					)}

					<!-- Sisu: src/content/koduleht/meist.md -->
					{entry.id === 'meist' && (
						<section class="about-section" id="about">
							<div class="about-grid">
								{communitySlides.length > 0 && (
									<div class="about-image about-carousel-wrap scroll-reveal">
										<GaleriiKarussell
											slides={communitySlides}
											intervalMs={7000}
											controlsLabel="Koguduse piltide valik"
											dotLabel="Näita koguduse pilti"
										/>
									</div>
								)}
								<div class="about-copy scroll-reveal" style="--reveal-delay: 100ms">
									<p class="eyebrow">{about.eyebrow}</p>
									<h2>{about.title}</h2>
									{about.description?.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
									{about.buttons && about.buttons.length > 0 && (
										<div class="about-actions">
											{about.buttons.map((button) => (
												<TegevusNupp {...button} />
											))}
										</div>
									)}
								</div>
							</div>
						</section>
					)}

					<!-- Sisu: src/content/koduleht/facebooki-uudised.md -->
					{entry.id === 'facebooki-uudised' && (
						<section class="facebook-section" id="facebook">
							<div class="section-inner social-panel">
								<div class="social-copy scroll-reveal">
									<p class="eyebrow">{facebook.eyebrow}</p>
									<h2>{facebook.title}</h2>
									{facebook.description && <p>{facebook.description}</p>}
									<div class="social-actions">
										{facebook.buttons?.map((button) => (
											<TegevusNupp {...button} />
										))}
									</div>
								</div>
								<FacebookiVoog pageUrl={facebookPageUrl} />
							</div>
						</section>
					)}

					<!-- Sisu: src/content/koduleht/jutlused-ja-raadiosaated.md -->
					{entry.id === 'jutlused-ja-raadiosaated' && (
						<section class="resources-section" id="audio">
							<div class="section-inner">
								<div class="scroll-reveal">
									<SektsiooniPealkiri eyebrow={audio.eyebrow} title={audio.title} description={audio.description} />
								</div>

								<div class="resource-groups">
									<article class="resource-group">
										<div class="advent-audio-blocks">
											{adventAudioBlocks.map((block) => (
												<div class="advent-audio-block">
													<div class="advent-audio-heading">
														<h4>{block.title}</h4>
														<TegevusNupp
															text={block.buttonText}
															link={block.sourceUrl}
															variant="secondary"
															external
															ariaLabel={`${block.buttonText}: ${block.title}`}
														/>
													</div>
													<div class="advent-audio-grid stagger">
														{block.items.map((item) => (
															<a class="advent-audio-card scroll-reveal" href={item.url} target="_blank" rel="noopener noreferrer">
																<div class="advent-audio-image" aria-hidden="true">
																	{block.imageUrl || item.imageUrl ? (
																		<img src={block.imageUrl ?? item.imageUrl} alt="" loading="lazy" />
																	) : (
																		<span />
																	)}
																</div>
																<div class="advent-audio-card-copy">
																	{item.date && <span>{item.date}</span>}
																	<h5>{item.title}</h5>
																</div>
															</a>
														))}
													</div>
												</div>
											))}
										</div>
									</article>
								</div>
							</div>
						</section>
					)}

					<!-- Sisu: src/content/koduleht/veebikoolitus.md -->
					{entry.id === 'veebikoolitus' && (
						<section class="course-section" id="kursus">
							<div class="course-container">

								<div class="course-top-row">
									<div class="course-copy-wrap scroll-reveal">
										{course.eyebrow && <p class="eyebrow">{course.eyebrow}</p>}
										<h2>{course.title}</h2>
										{course.description?.split('\n').filter(Boolean).map((p) => <p class="section-description">{p}</p>)}
										{course.buttons && course.buttons.length > 0 && (
											<div class="course-actions">
												{course.buttons.map((button) => (
													<TegevusNupp {...button} />
												))}
											</div>
										)}
									</div>

									<div class="course-video-wrap scroll-reveal" style="--reveal-delay: 100ms">
										<iframe
											id="course-video-iframe"
											class="course-video-iframe"
											src={`https://www.youtube.com/embed/${course.chapters?.[0]?.youtubeId ?? 'Dw_o0Fb3Pis'}?rel=0`}
											title="Usk ja elu veebikoolitus"
											allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen"
											allowfullscreen
										></iframe>
									</div>
								</div>

								{course.chapters && course.chapters.length > 0 && (
									<nav class="course-chapters scroll-reveal" style="--reveal-delay: 150ms" aria-label="Kursuse peatükid">
										<p class="course-chapters-label">Video peatükid</p>
										<div class="course-chapters-list">
											{course.chapters.map((chapter, i) => (
												<a
													class:list={['course-chapter-card', i === 0 && 'is-active']}
													href={chapter.link}
													data-course-url={chapter.link}
													data-youtube-id={chapter.youtubeId}
												>
													<span class="chapter-num">{String(chapter.number).padStart(2, '0')}</span>
													<span class="chapter-title">{chapter.title}</span>
													<svg class="chapter-arrow" width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
														<path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
													</svg>
												</a>
											))}
										</div>
									</nav>
								)}

							</div>
						</section>
					)}

					<!-- Sisu ja komponent: src/content/koduleht/oppetuki-app.md, src/components/HingamispaevakooliVidin.astro -->
					{entry.id === 'oppetuki-app' && (
						<HingamispaevakooliVidin />
					)}
				</>
			))}

			<!-- Sisu: src/content/koduleht/kontakt.md -->
			<section class="visit-section" id="contact">
				<div class="visit-header">
					<p class="eyebrow">{contactInfo.eyebrow}</p>
					<h2>{contactInfo.title}</h2>
				</div>
				<div class="visit-inner">
					{contactInfo.mapEmbedUrl && (
						<div class="contact-map">
							<iframe
								title={contactInfo.mapTitle ?? contactInfo.address}
								src={contactInfo.mapEmbedUrl}
								loading="eager"
								referrerpolicy="no-referrer-when-downgrade"
								allowfullscreen
							></iframe>
						</div>
					)}
					<div class="contact-card">
						<div class="visit-details">
							<h3>{contactInfo.cardTitle}</h3>
							{visibleContactItems.map((item) => (
								<p>
									<strong>{item.label}:</strong>{' '}
									{item.href ? (
										<a href={item.href}>{item.value}</a>
									) : (
										item.value
									)}
								</p>
							))}
						</div>
					</div>
				</div>
			</section>
		</main>
		<Jalus />
	</body>
</html>

<style>
	/* Üldine avalehe raam ja ühised elemendid */
	:global(body) {
		background: var(--color-page);
		color: var(--color-text);
	}

	.page-wrapper {
		width: 100%;
	}

	/* Avaleht: src/content/koduleht/avaleht.md */
	.hero-section {
		background: linear-gradient(160deg, var(--color-surface-soft) 0%, #fdf3e6 55%, var(--color-surface) 100%);
		padding: var(--hero-padding-top) var(--section-padding-x) var(--hero-padding-bottom);
		position: relative;
		overflow: hidden;
	}

	.hero-section::before {
		content: '';
		position: absolute;
		top: -100px;
		right: -60px;
		width: var(--hero-background-orb-size);
		height: var(--hero-background-orb-size);
		background: radial-gradient(circle, rgba(199, 102, 26, 0.07) 0%, transparent 68%);
		pointer-events: none;
	}

	.hero-section::after {
		content: '';
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(199, 102, 26, 0.055) 1px, transparent 1px);
		background-size: var(--hero-background-dot-size) var(--hero-background-dot-size);
		pointer-events: none;
		opacity: 0.6;
	}

	.hero-content,
	.section-inner,
	.about-grid,
	.visit-header,
	.visit-inner {
		max-width: var(--site-max-width);
		margin: 0 auto;
	}

	.hero-content {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: var(--hero-column-gap);
		align-items: center;
		position: relative;
	}

	.hero-carousel-wrap {
		position: relative;
	}

	.hero-copy {
		max-width: var(--hero-text-width);
	}

	.eyebrow {
		color: var(--color-accent);
		font-family: var(--font-heading);
		font-size: var(--eyebrow-font-size);
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 var(--hero-eyebrow-margin-bottom);
		text-transform: uppercase;
	}

	.hero-copy h1,
	.about-copy h2,
	.facebook-section .social-copy h2,
	.visit-inner h2 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-weight: 600;
		letter-spacing: 0;
	}

	.hero-copy h1 {
		font-size: var(--hero-title-size);
		letter-spacing: -0.02em;
		line-height: var(--hero-title-line-height);
		margin: 0;
	}

	.hero-intro {
		color: var(--color-text-soft);
		font-size: var(--hero-intro-font-size);
		line-height: var(--hero-intro-line-height);
		margin: var(--hero-intro-margin-top) 0 0;
		max-width: var(--hero-intro-width);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--hero-buttons-gap);
		margin-top: var(--hero-buttons-margin-top);
	}

	/* Meist: src/content/koduleht/meist.md */
	.about-image {
		border-radius: var(--contact-map-radius);
		overflow: hidden;
		box-shadow: 0 20px 60px rgba(117, 62, 19, 0.18),
		            0 4px 14px rgba(117, 62, 19, 0.1);
		outline: 1px solid var(--color-border);
		outline-offset: -1px;
		transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
		            box-shadow 0.4s ease;
	}

	.about-image:hover {
		transform: translateY(-4px);
		box-shadow: 0 28px 72px rgba(117, 62, 19, 0.2),
		            0 6px 18px rgba(117, 62, 19, 0.12);
	}

	.about-carousel-wrap,
	.about-carousel-wrap:hover {
		box-shadow: none;
		outline: 0;
		transform: none;
	}

	.about-image picture {
		display: block;
		height: 100%;
		width: 100%;
	}

	.about-image img {
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.hero-carousel-wrap,
	.about-carousel-wrap {
		justify-self: center;
		width: min(100%, var(--gallery-panel-width));
	}

	.info-section,
	.about-section,
	.facebook-section,
	.resources-section,
	.course-section,
	.app-section,
	.visit-section {
		padding: var(--section-padding-y) var(--section-padding-x);
	}

	.info-section,
	.resources-section,
	.app-section {
		background: var(--color-surface);
	}

	/* Ühised pealkirjad ja kirjeldused */
	.about-copy h2,
	.facebook-section .social-copy h2,
	.course-grid h2,
	.app-card h2,
	.visit-inner h2 {
		font-size: var(--section-title-size);
		letter-spacing: -0.01em;
		line-height: var(--section-title-line-height);
		margin: 0;
	}

	.section-description {
		color: var(--color-text-soft);
		font-size: var(--section-description-font-size);
		line-height: var(--section-description-line-height);
		margin: var(--section-description-margin-top) 0 0;
		max-width: var(--text-column-width);
	}

	/* Kogunemised: src/content/koduleht/kogunemised.md */
	.info-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--info-grid-gap);
		margin-top: var(--info-grid-margin-top);
	}

	.info-grid > .scroll-reveal {
		display: flex;
		flex-direction: column;
	}

	.info-grid > .scroll-reveal :global(.info-card) {
		flex: 1;
	}

	.service-schedule {
		margin-top: var(--schedule-margin-top);
	}

	.service-schedule-heading {
		max-width: var(--text-column-width);
	}

	.service-schedule-heading h3 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: var(--schedule-heading-size);
		line-height: 1.2;
		margin: 0;
	}

	.service-schedule-heading p {
		color: var(--color-text-soft);
		font-size: 1rem;
		line-height: 1.65;
		margin: 12px 0 0;
	}

	.service-schedule-grid {
		display: grid;
