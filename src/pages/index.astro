---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = Astro.site?.pathname || '/';
---

<html lang="et">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-wrapper">
			<section class="hero-section" id="home">
				<div class="hero-content">
					<div class="hero-copy">
						
						<h1>Oled oodatud meiega Jumalat teenima.</h1>
						<p class="hero-intro">
							Tule laupäeval kogudusse, et kuulata Jumala sõna, palvetada ja olla koos
							inimestega, kes soovivad kasvada usus ja armastuses.
						</p>
						<div class="hero-actions">
							<a class="button primary" href={`${base}#services`}>Jumalateenistused</a>
							<a class="button secondary" href={`${base}#contact`}>Võta ühendust</a>
						</div>
					</div>
					<div class="hero-image-card">
						<img
							src={`${base}images/kiriku-pilt.jpg`}
							alt="Keila adventkoguduse hoone väljast"
							width="6000"
							height="4000"
							loading="eager"
							fetchpriority="high"
							decoding="async"
						/>
					</div>
				</div>
			</section>

			<section class="info-section" id="services">
				<div class="section-inner">
					<div class="section-heading">
						<p class="eyebrow">Kohtume laupäeviti</p>
						<h2>Jumalateenistus ja piiblitund</h2>
					</div>
					<div class="info-grid">
						<article class="info-card">
							<h3>Jumalateenistus</h3>
							<p>
								Ootame sind laupäeviti kell 11.00 ühisele teenistusele, kus on laul,
								palve ja sõnum Piiblist.
							</p>
						</article>
						<article class="info-card">
							<h3>Piibli uurimine</h3>
							<p>
								Enne teenistust võtame aega, et koos Piiblit avada ja üksteise mõtteid
								kuulata.
							</p>
						</article>
						<article class="info-card">
							<h3>Kogukond</h3>
							<p>
								Meie koguduses on ruumi küsimustele, palvele ja sõbralikule osadusele.
							</p>
						</article>
					</div>
				</div>
			</section>

			<section class="about-section" id="about">
				<div class="about-grid">
					<div class="about-image">
						<img
							src={`${base}images/ulistus.jpg`}
							alt="Koguduse ülistus ja laulmine teenistusel"
							width="6000"
							height="3376"
							loading="lazy"
							decoding="async"
						/>
					</div>
					<div class="about-copy">
						<p class="eyebrow">Meist</p>
						<h2>Väike kogudus, avatud süda.</h2>
						<p>
							Keila Adventkogudus on kristlik kogukond, kus soovime koos õppida tundma
							Jeesust, toetada üksteist ja teenida oma linna heaga.
						</p>
						<p>
							Sa ei pea kõike teadma ega oskama. Tule nii, nagu oled. Meil on hea meel sind
							näha.
						</p>
					</div>
				</div>
			</section>

			<section class="visit-section" id="contact">
				<div class="visit-inner">
					<div>
						<p class="eyebrow">Ootame sind laupäeviti</p>
						<h2>Tule jumalateenistusele ja piiblitundi.</h2>
					</div>
					<div class="visit-details">
						<p><strong>Jumalateenistus:</strong> kell 11.00</p>
						<p><strong>Piiblitund:</strong> kell 12.00</p>
						<p><strong>Aadress:</strong> Põllu 5, Keila</p>
						<p><strong>Pastor:</strong> Marge Randlepp</p>
						<p><strong>Telefon:</strong> <a href="tel:+37256562131">56 56 21 31</a></p>
						<p>
							<strong>E-post:</strong>
							<a href="mailto:marge.randlepp@advent.ee">marge.randlepp@advent.ee</a>
						</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: #f7f4ef;
		color: #2f2f2f;
	}

	.page-wrapper {
		width: 100%;
	}

	.hero-section {
		background: linear-gradient(180deg, #f7f4ef 0%, #ffffff 100%);
		padding: 82px 20px 72px;
	}

	.hero-content,
	.section-inner,
	.about-grid,
	.visit-inner {
		max-width: 1180px;
		margin: 0 auto;
	}

	.hero-content {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(340px, 0.9fr);
		gap: 56px;
		align-items: center;
	}

	.hero-copy {
		max-width: 680px;
	}

	.eyebrow {
		color: #6d7f62;
		font-family: 'Cabin', sans-serif;
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 16px;
		text-transform: uppercase;
	}

	.hero-copy h1,
	.section-heading h2,
	.about-copy h2,
	.visit-inner h2 {
		color: #252525;
		font-family: 'DM Sans', sans-serif;
		font-weight: 600;
		letter-spacing: 0;
	}

	.hero-copy h1 {
		font-size: clamp(2.7rem, 6vw, 5rem);
		line-height: 1.04;
		margin: 0;
	}

	.hero-intro {
		color: #55514b;
		font-size: 1.15rem;
		line-height: 1.75;
		margin: 28px 0 0;
		max-width: 610px;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.button {
		border: 1px solid #2f557f;
		border-radius: 6px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: 'Inter', sans-serif;
		font-size: 0.98rem;
		font-weight: 500;
		min-height: 48px;
		padding: 0 24px;
		text-decoration: none;
	}

	.button.primary {
		background: #2f557f;
		color: #ffffff;
	}

	.button.secondary {
		background: transparent;
		color: #2f557f;
	}

	.button:hover {
		border-color: #213d5f;
		color: #ffffff;
		background: #213d5f;
	}

	.hero-image-card,
	.about-image {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 24px 70px rgba(55, 48, 39, 0.14);
	}

	.hero-image-card {
		aspect-ratio: 4 / 5;
	}

	.hero-image-card img,
	.about-image img {
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.info-section,
	.about-section,
	.visit-section {
		padding: 78px 20px;
	}

	.info-section {
		background: #ffffff;
	}

	.section-heading {
		max-width: 720px;
	}

	.section-heading h2,
	.about-copy h2,
	.visit-inner h2 {
		font-size: clamp(2rem, 4vw, 3.25rem);
		line-height: 1.12;
		margin: 0;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 38px;
	}

	.info-card {
		background: #f7f4ef;
		border: 1px solid #e7dfd4;
		border-radius: 8px;
		padding: 28px;
	}

	.info-card h3 {
		color: #263f35;
		font-family: 'DM Sans', sans-serif;
		font-size: 1.35rem;
		margin: 0 0 14px;
	}

	.info-card p,
	.about-copy p,
	.visit-details p {
		color: #55514b;
		font-size: 1rem;
		line-height: 1.75;
		margin: 0;
	}

	.about-section {
		background: #f7f4ef;
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1fr);
		gap: 58px;
		align-items: center;
	}

	.about-image {
		aspect-ratio: 5 / 4;
	}

	.about-copy p {
		margin-top: 22px;
	}

	.visit-section {
		background: #2f557f;
		color: #ffffff;
	}

	.visit-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.65fr);
		gap: 48px;
		align-items: start;
	}

	.visit-section .eyebrow,
	.visit-inner h2,
	.visit-details p {
		color: #ffffff;
	}

	.visit-details {
		background: rgba(255, 255, 255, 0.09);
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 8px;
		padding: 28px;
	}

	.visit-details a {
		color: #ffffff;
		text-decoration-color: rgba(255, 255, 255, 0.58);
		text-underline-offset: 3px;
	}

	.visit-details a:hover {
		text-decoration-color: #ffffff;
	}

	.visit-details p + p {
		margin-top: 12px;
	}

	@media (max-width: 860px) {
		.hero-section {
			padding: 52px 18px 54px;
		}

		.hero-content,
		.about-grid,
		.visit-inner {
			grid-template-columns: 1fr;
			gap: 34px;
		}

		.hero-image-card {
			aspect-ratio: 16 / 11;
		}

		.info-section,
		.about-section,
		.visit-section {
			padding: 56px 18px;
		}

		.info-grid {
			grid-template-columns: 1fr;
		}

		.info-card {
			padding: 24px;
		}
	}

	@media (max-width: 520px) {
		.hero-copy h1 {
			font-size: 2.35rem;
		}

		.hero-actions,
		.button {
			width: 100%;
		}
	}
</style>
