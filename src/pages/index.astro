<script>
	// Course — chapter navigation
	const chapterLinks = document.querySelectorAll<HTMLAnchorElement>('.course-chapter-card[data-course-url]');
	const videoThumb = document.getElementById('course-video-thumb') as HTMLImageElement | null;
	const videoLink = document.getElementById('course-video-link') as HTMLAnchorElement | null;

	chapterLinks.forEach((link) => {
		link.addEventListener('click', (e) => {
			const youtubeId = link.dataset.youtubeId;
			const watchUrl = link.dataset.courseUrl;
			if (!youtubeId) return;
			e.preventDefault();
			if (videoThumb) videoThumb.src = `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`;
			if (videoLink && watchUrl) videoLink.href = watchUrl;
			chapterLinks.forEach((l) => l.classList.remove('is-active'));
			link.classList.add('is-active');
		});
	});
</script>
