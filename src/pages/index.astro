---
import { Picture } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ContentCard from '../components/ContentCard.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import heroImage from '../assets/images/kiriku-pilt.jpg';
import worshipImage from '../assets/images/ulistus.jpg';

const homepageEntries = await getCollection('homepage');
const homepage = Object.fromEntries(homepageEntries.map((entry) => [entry.id, entry.data]));
const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
const sermons = (await getCollection('sermons', ({ data }) => !data.draft)).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
const ministryItems = (await getCollection('ministry')).sort((a, b) => a.data.order - b.data.order);
const [contact] = await getCollection('contact');
const [siteEntry] = await getCollection('site');
const site = siteEntry.data;

const hero = homepage.hero;
const services = homepage.services;
const about = homepage.about;
const facebook = homepage.facebook;
const resources = homepage.resources;
const course = homepage.course;
const app = homepage.app;
const contactInfo = contact.data;
const articleCards = articles.filter((entry) => entry.data.category !== 'Tervis');
const healthCards = articles.filter((entry) => entry.data.category === 'Tervis');
const imageAssets = {
	'/images/kiriku-pilt.jpg': heroImage,
	'/images/ulistus.jpg': worshipImage,
};

const heroAsset = hero.image ? imageAssets[hero.image] : heroImage;
const aboutAsset = about.image ? imageAssets[about.image] : worshipImage;
---

<html lang="et">
	<head>
		<BaseHead title={site.title} description={site.description} siteTitle={site.title} image={heroImage} />
	</head>
	<body>
		<Header />
		<main class="page-wrapper">
			<section class="hero-section" id="home">
				<div class="hero-content">
					<div class="hero-copy">
						
						<h1>{hero.title}</h1>
						<p class="hero-intro">{hero.description}</p>
						<div class="hero-actions">
							{hero.buttons?.map((button) => (
								<a class={`button ${button.variant}`} href={button.link}>{button.text}</a>
							))}
						</div>
					</div>
					<div class="hero-image-card">
						<Picture
							src={heroAsset}
							formats={['webp']}
							widths={[640, 960, 1200]}
							sizes="(max-width: 860px) calc(100vw - 36px), min(42vw, 500px)"
							alt={hero.imageAlt ?? ''}
							width="6000"
							height="4000"
							loading="eager"
							quality={85}
						/>
					</div>
				</div>
			</section>

			<section class="info-section" id="services">
				<div class="section-inner">
					<div class="section-heading">
						<p class="eyebrow">{services.eyebrow}</p>
						<h2>{services.title}</h2>
					</div>
					<div class="info-grid">
						{services.cards?.map((card) => (
							<article class="info-card">
								<h3>{card.title}</h3>
								<p>{card.description}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="about-section" id="about">
				<div class="about-grid">
					<div class="about-image">
						<Picture
							src={aboutAsset}
							formats={['webp']}
							widths={[640, 960, 1200]}
							sizes="(max-width: 860px) calc(100vw - 36px), min(43vw, 530px)"
							alt={about.imageAlt ?? ''}
							loading="lazy"
							quality={85}
						/>
					</div>
					<div class="about-copy">
						<p class="eyebrow">{about.eyebrow}</p>
						<h2>{about.title}</h2>
						{about.description?.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
					</div>
				</div>
			</section>

			<section class="facebook-section" id="facebook">
				<div class="section-inner social-panel">
					<div class="section-heading">
						<p class="eyebrow">{facebook.eyebrow}</p>
						<h2>{facebook.title}</h2>
						<p class="section-description">{facebook.description}</p>
					</div>
					{facebook.buttons?.map((button) => (
						<a
							class={`button ${button.variant}`}
							href={button.link}
							target={button.external ? '_blank' : undefined}
							rel={button.external ? 'noopener noreferrer' : undefined}
							aria-label={button.ariaLabel}
						>
							{button.text}
						</a>
					))}
				</div>
			</section>

			<section class="resources-section" id="materjalid">
				<div class="section-inner">
					<div class="section-heading">
						<p class="eyebrow">{resources.eyebrow}</p>
						<h2>{resources.title}</h2>
						<p class="section-description">{resources.description}</p>
					</div>

					<ul class="category-list" aria-label="Materjalide kategooriad">
						{resources.categories?.map((category) => <li>{category}</li>)}
					</ul>

					<div class="resource-groups">
						<article class="resource-group">
							<div class="resource-group-heading">
								<p class="eyebrow">Artiklid</p>
								<h3>Lugemiseks ja mõtisklemiseks</h3>
							</div>
							<div class="resource-card-grid">
								{articleCards.map((entry) => (
									<ContentCard
										title={entry.data.title}
										label={entry.data.category}
										href={`articles/${entry.id}/`}
									/>
								))}
							</div>
						</article>

						<article class="resource-group">
							<div class="resource-group-heading">
								<p class="eyebrow">Audio</p>
								<h3>Jutlused ja kuulamiseks mõeldud mõtted</h3>
							</div>
							<div class="resource-card-grid compact">
								{sermons.map((entry) => (
									<ContentCard
										title={entry.data.title}
										label={entry.data.category}
										href={`sermons/${entry.id}/`}
									/>
								))}
							</div>
						</article>

						<article class="resource-group">
							<div class="resource-group-heading">
								<p class="eyebrow">Tervis</p>
								<h3>Terviseartiklid</h3>
							</div>
							<div class="resource-card-grid compact">
								{healthCards.map((entry) => (
									<ContentCard
										title={entry.data.title}
										label={entry.data.category}
										href={`articles/${entry.id}/`}
									/>
								))}
							</div>
						</article>

						<div class="format-grid" aria-label="Lisamaterjalide tüübid">
							{ministryItems.map((entry) => (
								<article class="info-card">
									<h3>{entry.data.title}</h3>
									<p>{entry.data.description}</p>
								</article>
							))}
						</div>
					</div>
				</div>
			</section>

			<section class="course-section" id="kursus">
				<div class="course-grid">
					<div>
						<p class="eyebrow">{course.eyebrow}</p>
						<h2>{course.title}</h2>
						<p class="section-description">{course.description}</p>
						{course.buttons?.map((button) => (
							<a
								class={`button ${button.variant}`}
								href={button.link}
								target={button.external ? '_blank' : undefined}
								rel={button.external ? 'noopener noreferrer' : undefined}
							>
								{button.text}
							</a>
						))}
					</div>
					<ul class="theme-list" aria-label="Usk ja elu kursuse teemad">
						{course.themes?.map((theme) => <li>{theme}</li>)}
					</ul>
				</div>
			</section>

			<section class="app-section" id="oppetykk">
				<div class="section-inner app-card">
					<div>
						<p class="eyebrow">{app.eyebrow}</p>
						<h2>{app.title}</h2>
						<p class="section-description">{app.description}</p>
					</div>
					{app.buttons?.map((button) => (
						<a
							class={`button ${button.variant}`}
							href={button.link}
							target={button.external ? '_blank' : undefined}
							rel={button.external ? 'noopener noreferrer' : undefined}
						>
							{button.text}
						</a>
					))}
				</div>
			</section>

			<section class="visit-section" id="contact">
				<div class="visit-inner">
					<div class="visit-copy">
						<p class="eyebrow">{contactInfo.eyebrow}</p>
						<h2>{contactInfo.title}</h2>
					</div>
					<div class="contact-card">
						<div class="visit-details">
							<h3>Kontakt</h3>
							<p><strong>Jumalateenistus:</strong> {contactInfo.serviceTime}</p>
							<p><strong>Piiblitund:</strong> {contactInfo.bibleStudyTime}</p>
							<p><strong>Aadress:</strong> {contactInfo.address}</p>
							<p><strong>Pastor:</strong> {contactInfo.pastor}</p>
							<p><strong>Telefon:</strong> <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a></p>
							<p>
								<strong>E-post:</strong>
								<a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
							</p>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: #f7f4ef;
		color: #2f2f2f;
	}

	.page-wrapper {
		width: 100%;
	}

	.hero-section {
		background: linear-gradient(180deg, #f7f4ef 0%, #ffffff 100%);
		padding: 82px 20px 72px;
	}

	.hero-content,
	.section-inner,
	.about-grid,
	.visit-inner {
		max-width: 1180px;
		margin: 0 auto;
	}

	.hero-content {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(340px, 0.9fr);
		gap: 56px;
		align-items: center;
	}

	.hero-copy {
		max-width: 680px;
	}

	.eyebrow {
		color: #6d7f62;
		font-family: var(--font-heading);
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 16px;
		text-transform: uppercase;
	}

	.hero-copy h1,
	.section-heading h2,
	.about-copy h2,
	.visit-inner h2 {
		color: #252525;
		font-family: var(--font-heading);
		font-weight: 600;
		letter-spacing: 0;
	}

	.hero-copy h1 {
		font-size: clamp(2.7rem, 6vw, 5rem);
		line-height: 1.04;
		margin: 0;
	}

	.hero-intro {
		color: #55514b;
		font-size: 1.15rem;
		line-height: 1.75;
		margin: 28px 0 0;
		max-width: 610px;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.button {
		border: 1px solid #2f557f;
		border-radius: 6px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-body);
		font-size: 0.98rem;
		font-weight: 500;
		min-height: 48px;
		padding: 0 24px;
		text-decoration: none;
	}

	.button.primary {
		background: #2f557f;
		color: #ffffff;
	}

	.button.secondary {
		background: transparent;
		color: #2f557f;
	}

	.button:hover {
		border-color: #213d5f;
		color: #ffffff;
		background: #213d5f;
	}

	.hero-image-card,
	.about-image {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 24px 70px rgba(55, 48, 39, 0.14);
	}

	.hero-image-card {
		aspect-ratio: 4 / 5;
	}

	.hero-image-card picture,
	.about-image picture {
		display: block;
		height: 100%;
		width: 100%;
	}

	.hero-image-card img,
	.about-image img {
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.info-section,
	.about-section,
	.facebook-section,
	.resources-section,
	.course-section,
	.app-section,
	.visit-section {
		padding: 78px 20px;
	}

	.info-section,
	.resources-section,
	.app-section {
		background: #ffffff;
	}

	.section-heading {
		max-width: 720px;
	}

	.section-heading h2,
	.about-copy h2,
	.course-grid h2,
	.app-card h2,
	.visit-inner h2 {
		font-size: clamp(2rem, 4vw, 3.25rem);
		line-height: 1.12;
		margin: 0;
	}

	.section-description {
		color: #55514b;
		font-size: 1.05rem;
		line-height: 1.75;
		margin: 22px 0 0;
		max-width: 680px;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 38px;
	}

	.info-card {
		background: #f7f4ef;
		border: 1px solid #e7dfd4;
		border-radius: 8px;
		padding: 28px;
	}

	.info-card h3 {
		color: #263f35;
		font-family: var(--font-heading);
		font-size: 1.35rem;
		margin: 0 0 14px;
	}

	.info-card p,
	.resource-card h4,
	.about-copy p,
	.visit-details p {
		color: #55514b;
		font-size: 1rem;
		line-height: 1.75;
		margin: 0;
	}

	.about-section {
		background: #f7f4ef;
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1fr);
		gap: 58px;
		align-items: center;
	}

	.about-image {
		aspect-ratio: 5 / 4;
	}

	.about-copy p {
		margin-top: 22px;
	}

	.facebook-section {
		background: #f7f4ef;
	}

	.social-panel,
	.app-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 40px;
	}

	.category-list,
	.theme-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		list-style: none;
		margin: 34px 0 0;
		padding: 0;
	}

	.category-list li,
	.theme-list li {
		background: #f7f4ef;
		border: 1px solid #e7dfd4;
		border-radius: 999px;
		color: #263f35;
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1;
		padding: 12px 16px;
	}

	.resource-groups {
		display: grid;
		gap: 38px;
		margin-top: 44px;
	}

	.resource-group {
		border-top: 1px solid #e7dfd4;
		padding-top: 34px;
	}

	.resource-group-heading {
		margin-bottom: 22px;
		max-width: 720px;
	}

	.resource-group-heading h3 {
		color: #252525;
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 3vw, 2rem);
		margin: 0;
	}

	.resource-card-grid,
	.format-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.resource-card {
		background: #f7f4ef;
		border: 1px solid #e7dfd4;
		border-radius: 8px;
		min-height: 132px;
		padding: 24px;
	}

	.resource-card span {
		color: #6d7f62;
		display: block;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		margin-bottom: 12px;
		text-transform: uppercase;
	}

	.resource-card h4 {
		color: #263f35;
		font-family: var(--font-heading);
		font-size: 1.14rem;
		font-weight: 600;
	}

	.course-section {
		background: #f7f4ef;
	}

	.course-grid {
		max-width: 1180px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.7fr);
		gap: 58px;
		align-items: center;
	}

	.course-grid .button {
		margin-top: 32px;
	}

	.theme-list {
		align-content: start;
		background: #ffffff;
		border: 1px solid #e7dfd4;
		border-radius: 8px;
		margin: 0;
		padding: 28px;
	}

	.app-card {
		background: #f7f4ef;
		border: 1px solid #e7dfd4;
		border-radius: 8px;
		padding: 34px;
	}

	.visit-section {
		background: #2f557f;
		color: #ffffff;
	}

	.visit-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.65fr);
		gap: 48px;
		align-items: start;
	}

	.visit-copy {
		max-width: 560px;
	}

	.contact-card {
		align-self: stretch;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 24px;
		padding: 18px;
	}

	.visit-section .eyebrow,
	.visit-inner h2,
	.visit-details h3,
	.visit-details p {
		color: #ffffff;
	}

	.visit-details {
		background: rgba(255, 255, 255, 0.16);
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 16px;
		box-shadow: 0 24px 48px rgba(0, 0, 0, 0.14);
		padding: 34px;
	}

	.visit-details h3 {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		margin: 0 0 18px;
	}

	.visit-details a {
		color: #ffffff;
		text-decoration-color: rgba(255, 255, 255, 0.58);
		text-underline-offset: 3px;
	}

	.visit-details a:hover {
		text-decoration-color: #ffffff;
	}

	.visit-details p + p {
		margin-top: 12px;
	}

	@media (max-width: 860px) {
		.hero-section {
			padding: 52px 18px 54px;
		}

		.hero-content,
		.about-grid,
		.visit-inner {
			grid-template-columns: 1fr;
			gap: 34px;
		}

		.hero-image-card {
			aspect-ratio: 16 / 11;
		}

		.info-section,
		.about-section,
		.facebook-section,
		.resources-section,
		.course-section,
		.app-section,
		.visit-section {
			padding: 56px 18px;
		}

		.info-grid,
		.resource-card-grid,
		.format-grid {
			grid-template-columns: 1fr;
		}

		.info-card {
			padding: 24px;
		}

		.social-panel,
		.app-card {
			align-items: stretch;
			flex-direction: column;
		}

		.course-grid {
			grid-template-columns: 1fr;
			gap: 32px;
		}

		.app-card {
			padding: 28px;
		}
	}

	@media (max-width: 520px) {
		.hero-copy h1 {
			font-size: 2.35rem;
		}

		.hero-actions,
		.button {
			width: 100%;
		}
	}
</style>
