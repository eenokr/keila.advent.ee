---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import AnnouncementCarousel from '../components/AnnouncementCarousel.astro';
import BaseHead from '../components/BaseHead.astro';
import CtaButton from '../components/CtaButton.astro';
import FacebookFeed from '../components/FacebookFeed.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import InfoCard from '../components/InfoCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { ADVENT_AUDIO_SOURCES, getAdventAudioItems } from '../lib/adventAudio';
import { getServiceScheduleItems } from '../lib/serviceSchedule';

const SERVICE_SCHEDULE_CSV_URL =
	'https://docs.google.com/spreadsheets/d/e/2PACX-1vTOmThNzJymlMrI5PiXxN5jcQTAotZvXrbYCZwDWQ8s2fqvbOckV6-XjCFkyUulLYUUl0HOqpyYIxrO/pub?gid=1165865253&single=true&output=csv';

const imageModules = import.meta.glob<ImageMetadata>('../assets/images/*', {
	eager: true,
	import: 'default',
});
const announcementImageModules = import.meta.glob<ImageMetadata>('../assets/announcements/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}', {
	eager: true,
	import: 'default',
});
const iconModules = import.meta.glob<string>('../assets/icons/*', {
	eager: true,
	import: 'default',
	query: '?url',
});

const homepageEntries = await getCollection('homepage');
const [siteEntry] = await getCollection('site');
const [contact] = await getCollection('contact');
const site = siteEntry.data;
const homepage = Object.fromEntries(homepageEntries.map((entry) => [entry.id, entry.data]));
const orderedHomepageEntries = homepageEntries.sort((a, b) => a.data.order - b.data.order);

const hero = homepage.hero;
const services = homepage.services;
const about = homepage.about;
const facebook = homepage.facebook;
const audio = homepage.audio;
const course = homepage.course;
const app = homepage.app;
const contactInfo = contact.data;
const serviceScheduleActivities = services.scheduleActivities ?? [
	{
		key: 'jutlus',
		positiveText: 'Jutlus toimub',
		negativeText: 'Jutlust ei toimu',
		icon: 'jumalateenistus1.svg',
		iconAlt: 'Jutlus',
	},
	{
		key: 'piiblitund',
		positiveText: 'Piiblitund toimub',
		negativeText: 'Piiblitundi ei toimu',
		icon: 'bible1.svg',
		iconAlt: 'Piiblitund',
	},
	{
		key: 'lasteTundRl',
		positiveText: 'Lastetund toimub',
		negativeText: 'Lastetund ei toimu',
		icon: 'lastetund.svg',
		iconAlt: 'Lastetund',
	},
	{
		key: 'soomine',
		positiveText: 'Söömine toimub',
		negativeText: 'Söömine ei toimu',
		icon: 'uhine-soomine.webp',
		iconAlt: 'Söömine',
	},
	{
		key: 'osasaamine',
		positiveText: 'Osasaamine toimub',
		negativeText: 'Osasaamine ei toimu',
		icon: 'osasaamise.svg',
		iconAlt: 'Osasaamine',
	},
] as const;

function getImage(filename?: string) {
	if (!filename) return undefined;

	return imageModules[`../assets/images/${filename}`];
}

function getIcon(filename?: string) {
	if (!filename) return undefined;
	if (filename.startsWith('http') || filename.startsWith('data:')) return filename;

	return iconModules[`../assets/icons/${filename.replace(/^\/?(images\/icons\/)?/, '')}`];
}

function getAnnouncementAlt(path: string) {
	const filename = path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? 'teade';
	const title = filename.replace(/[-_]+/g, ' ').trim();

	return title ? `Koguduse teade: ${title}` : 'Koguduse teade';
}

const heroAsset = getImage(hero.image);
const aboutAsset = getImage(about.image);
const announcementSlides = Object.entries(announcementImageModules)
	.sort(([pathA], [pathB]) => pathA.localeCompare(pathB, 'et'))
	.map(([path, image]) => ({
		image,
		alt: getAnnouncementAlt(path),
	}));
const heroSlides = announcementSlides.length > 0
	? announcementSlides
	: heroAsset
		? [{ image: heroAsset, alt: hero.imageAlt ?? 'Keila adventkoguduse teade' }]
		: [];
const facebookPageUrl = facebook.pageUrl ?? facebook.buttons?.find((button) => button.link.includes('facebook.com'))?.link;
const [serviceScheduleItems, uheskoosAudioItems, sermonAudioItems] = await Promise.all([
	getServiceScheduleItems(SERVICE_SCHEDULE_CSV_URL, 4),
	getAdventAudioItems(ADVENT_AUDIO_SOURCES.uheskoos, 4),
	getAdventAudioItems(ADVENT_AUDIO_SOURCES.sermons, 4),
]);
const audioItemsByKey = {
	uheskoos: uheskoosAudioItems,
	sermons: sermonAudioItems,
};
const adventAudioBlocks = (audio.audioSources ?? [])
	.map((source) => ({
		...source,
		imageUrl: getImage(source.image)?.src,
		items: audioItemsByKey[source.key],
	}))
	.filter((block) => block.items.length > 0);
---

<html lang="et">
	<head>
		<BaseHead title={site.title} description={site.description} siteTitle={site.title} image={heroAsset} />
	</head>
	<body>
		<Header />
		<main class="page-wrapper">
			{orderedHomepageEntries.map((entry) => (
				<>
					{entry.id === 'hero' && (
						<section class="hero-section" id="home">
							<div class="hero-content">
								<div class="hero-copy">
									<h1>{hero.title}</h1>
									<p class="hero-intro">{hero.description}</p>
									<div class="hero-actions">
										{hero.buttons?.map((button) => (
											<CtaButton {...button} />
										))}
									</div>
								</div>
								<AnnouncementCarousel slides={heroSlides} intervalMs={6000} />
							</div>
						</section>
					)}

					{entry.id === 'services' && (
						<section class="info-section" id="services">
							<div class="section-inner">
								<SectionHeading eyebrow={services.eyebrow} title={services.title} description={services.description} />
								{services.cards && services.cards.length > 0 && (
									<div class="info-grid">
										{services.cards.map((card) => (
											<InfoCard {...card} />
										))}
									</div>
								)}
								{serviceScheduleItems.length > 0 && (
									<div class="service-schedule">
										<div class="service-schedule-grid">
											{serviceScheduleItems.map((item) => (
												<article
													class:list={[
														'service-schedule-card',
														!serviceScheduleActivities.some((activity) => item[activity.key]) && 'is-empty',
													]}
												>
													<h4>{item.date}</h4>
													{serviceScheduleActivities.some((activity) => item[activity.key]) ? (
														<ul class="service-schedule-list">
															{serviceScheduleActivities
																.filter((activity) => item[activity.key])
																.map((activity) => {
																	const activityIcon = getIcon(activity.icon);

																	return (
																		<li>
																			{activityIcon && <img src={activityIcon} alt={activity.iconAlt ?? ''} loading="lazy" />}
																			<span>{activity.positiveText}</span>
																		</li>
																	);
																})}
														</ul>
													) : (
														<div class="service-schedule-empty" aria-label="Sel päeval tegevusi ei toimu">
															<img class="schedule-lock" src={getIcon('lukk.svg')} alt="" loading="lazy" />
														</div>
													)}
												</article>
											))}
										</div>
									</div>
								)}
							</div>
						</section>
					)}

					{entry.id === 'about' && (
						<section class="about-section" id="about">
							<div class="about-grid">
								{aboutAsset && (
									<div class="about-image">
										<Picture
											src={aboutAsset}
											formats={['webp']}
											widths={[640, 960, 1200]}
											sizes="(max-width: 860px) calc(100vw - 36px), min(43vw, 530px)"
											alt={about.imageAlt ?? ''}
											loading="lazy"
											quality={85}
										/>
									</div>
								)}
								<div class="about-copy">
									<p class="eyebrow">{about.eyebrow}</p>
									<h2>{about.title}</h2>
									{about.description?.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
								</div>
							</div>
						</section>
					)}

					{entry.id === 'facebook' && (
						<section class="facebook-section" id="facebook">
							<div class="section-inner social-panel">
								<div class="social-copy">
									<p class="eyebrow">{facebook.eyebrow}</p>
									<h2>{facebook.title}</h2>
									{facebook.description && <p>{facebook.description}</p>}
									<div class="social-actions">
										{facebook.buttons?.map((button) => (
											<CtaButton {...button} />
										))}
									</div>
								</div>
								<FacebookFeed pageUrl={facebookPageUrl} />
							</div>
						</section>
					)}

					{entry.id === 'audio' && (
						<section class="resources-section" id="audio">
							<div class="section-inner">
								<SectionHeading eyebrow={audio.eyebrow} title={audio.title} description={audio.description} />

								<div class="resource-groups">
									<article class="resource-group">
										<div class="advent-audio-blocks">
											{adventAudioBlocks.map((block) => (
												<div class="advent-audio-block">
													<div class="advent-audio-heading">
														<h4>{block.title}</h4>
														<CtaButton
															text={block.buttonText}
															link={block.sourceUrl}
															variant="secondary"
															external
															ariaLabel={`${block.buttonText}: ${block.title}`}
														/>
													</div>
													<div class="advent-audio-grid">
														{block.items.map((item) => (
															<a class="advent-audio-card" href={item.url} target="_blank" rel="noopener noreferrer">
																<div class="advent-audio-image" aria-hidden="true">
																	{block.imageUrl || item.imageUrl ? (
																		<img src={block.imageUrl ?? item.imageUrl} alt="" loading="lazy" />
																	) : (
																		<span />
																	)}
																</div>
																<div class="advent-audio-card-copy">
																	{item.date && <span>{item.date}</span>}
																	<h5>{item.title}</h5>
																	<p>Kuula advent.ee lehel</p>
																</div>
															</a>
														))}
													</div>
												</div>
											))}
										</div>
									</article>
								</div>
							</div>
						</section>
					)}

					{entry.id === 'course' && (
						<section class="course-section" id="kursus">
							<div class="course-grid">
								<div>
									<p class="eyebrow">{course.eyebrow}</p>
									<h2>{course.title}</h2>
									<p class="section-description">{course.description}</p>
									<div class="course-actions">
										{course.buttons?.map((button) => (
											<CtaButton {...button} />
										))}
									</div>
								</div>
								<ul class="theme-list" aria-label={course.themesLabel}>
									{course.themes?.map((theme) => <li>{theme}</li>)}
								</ul>
							</div>
						</section>
					)}

					{entry.id === 'app' && (
						<section class="app-section" id="oppetykk">
							<div class="section-inner app-card">
								<div>
									<p class="eyebrow">{app.eyebrow}</p>
									<h2>{app.title}</h2>
									<p class="section-description">{app.description}</p>
								</div>
								{app.buttons?.map((button) => (
									<CtaButton {...button} />
								))}
							</div>
						</section>
					)}
				</>
			))}

			<section class="visit-section" id="contact">
				<div class="visit-inner">
					<div class="visit-copy">
						<p class="eyebrow">{contactInfo.eyebrow}</p>
						<h2>{contactInfo.title}</h2>
						{contactInfo.mapEmbedUrl && (
							<div class="contact-map">
								<iframe
									title={contactInfo.mapTitle ?? contactInfo.address}
									src={contactInfo.mapEmbedUrl}
									loading="eager"
									referrerpolicy="no-referrer-when-downgrade"
									allowfullscreen
								></iframe>
							</div>
						)}
					</div>
					<div class="contact-card">
						<div class="visit-details">
							<h3>{contactInfo.cardTitle}</h3>
							<p><strong>{contactInfo.fields.serviceTime}:</strong> {contactInfo.serviceTime}</p>
							<p><strong>{contactInfo.fields.bibleStudyTime}:</strong> {contactInfo.bibleStudyTime}</p>
							<p><strong>{contactInfo.fields.address}:</strong> {contactInfo.address}</p>
							<p><strong>{contactInfo.fields.pastor}:</strong> {contactInfo.pastor}</p>
							<p><strong>{contactInfo.fields.phone}:</strong> <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a></p>
							<p>
								<strong>{contactInfo.fields.email}:</strong>
								<a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
							</p>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: var(--color-page);
		color: var(--color-text);
	}

	.page-wrapper {
		width: 100%;
	}

	.hero-section {
		background: linear-gradient(180deg, var(--color-surface-soft) 0%, var(--color-surface) 100%);
		padding: 82px 20px 72px;
	}

	.hero-content,
	.section-inner,
	.about-grid,
	.visit-inner {
		max-width: 1180px;
		margin: 0 auto;
	}

	.hero-content {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(340px, 0.9fr);
		gap: 56px;
		align-items: center;
	}

	.hero-copy {
		max-width: 680px;
	}

	.eyebrow {
		color: var(--color-accent);
		font-family: var(--font-heading);
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 16px;
		text-transform: uppercase;
	}

	.hero-copy h1,
	.about-copy h2,
	.facebook-section .social-copy h2,
	.visit-inner h2 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-weight: 600;
		letter-spacing: 0;
	}

	.hero-copy h1 {
		font-size: clamp(2.7rem, 6vw, 5rem);
		line-height: 1.04;
		margin: 0;
	}

	.hero-intro {
		color: var(--color-text-soft);
		font-size: 1.15rem;
		line-height: 1.75;
		margin: 28px 0 0;
		max-width: 610px;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.about-image {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: var(--shadow-warm);
	}

	.about-image picture {
		display: block;
		height: 100%;
		width: 100%;
	}

	.about-image img {
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.info-section,
	.about-section,
	.facebook-section,
	.resources-section,
	.course-section,
	.app-section,
	.visit-section {
		padding: 78px 20px;
	}

	.info-section,
	.resources-section,
	.app-section {
		background: var(--color-surface);
	}

	.about-copy h2,
	.facebook-section .social-copy h2,
	.course-grid h2,
	.app-card h2,
	.visit-inner h2 {
		font-size: clamp(2rem, 4vw, 3.25rem);
		line-height: 1.12;
		margin: 0;
	}

	.section-description {
		color: var(--color-text-soft);
		font-size: 1.05rem;
		line-height: 1.75;
		margin: 22px 0 0;
		max-width: 680px;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 38px;
	}

	.service-schedule {
		margin-top: 38px;
	}

	.service-schedule-heading {
		max-width: 680px;
	}

	.service-schedule-heading h3 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: clamp(1.35rem, 2.4vw, 1.8rem);
		line-height: 1.2;
		margin: 0;
	}

	.service-schedule-heading p {
		color: var(--color-text-soft);
		font-size: 1rem;
		line-height: 1.65;
		margin: 12px 0 0;
	}

	.service-schedule-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 18px;
		margin-top: 22px;
	}

	.service-schedule-card {
		background: var(--color-surface-warm);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		min-height: 240px;
		padding: 24px;
	}

	.service-schedule-card h4 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: 1.55rem;
		line-height: 1.25;
		margin: 0 0 12px;
	}

	.service-schedule-list {
		color: var(--color-text-soft);
		font-size: 1.2rem;
		line-height: 1.55;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.service-schedule-list li {
		align-items: center;
		display: flex;
		gap: 14px;
		list-style: none;
	}

	.service-schedule-list li::marker {
		content: '';
	}

	.service-schedule-list li + li {
		margin-top: 7px;
	}

	.service-schedule-list img {
		flex: 0 0 auto;
		height: 32px;
		object-fit: contain;
		width: 32px;
	}

	.service-schedule-card.is-empty {
		align-items: center;
		border-color: transparent;
		display: flex;
		flex-direction: column;
		min-height: 154px;
	}

	.service-schedule-card.is-empty h4 {
		align-self: stretch;
	}

	.service-schedule-empty {
		display: grid;
		flex: 1;
		place-items: center;
		transform: translateY(-10px);
		width: 100%;
	}

	.schedule-lock {
		height: 124px;
		opacity: 0.55;
		object-fit: contain;
		width: 124px;
	}

	.about-copy p,
	.facebook-section .social-copy p:not(.eyebrow),
	.visit-details p {
		color: var(--color-text-soft);
		font-size: 1rem;
		line-height: 1.75;
		margin: 0;
	}

	.about-section {
		background: var(--color-surface-warm);
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1fr);
		gap: 58px;
		align-items: center;
	}

	.about-image {
		aspect-ratio: 5 / 4;
	}

	.about-copy p {
		margin-top: 22px;
	}

	.facebook-section .social-copy p:not(.eyebrow) {
		margin-top: 22px;
	}

	.facebook-section {
		background: var(--color-surface-warm);
	}

	.facebook-section .social-panel {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 500px);
		align-items: center;
		gap: 58px;
	}

	.facebook-section .social-panel :global(.facebook-feed),
	.facebook-section .social-panel :global(.facebook-feed-empty) {
		justify-self: end;
		width: min(100%, 500px);
	}

	.facebook-section .social-copy {
		justify-self: start;
		text-align: left;
	}

	.social-copy {
		max-width: 420px;
	}

	.social-panel,
	.app-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 40px;
	}

	.social-copy {
		max-width: 800px;
	}

	.social-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 30px;
	}

	.category-list,
	.theme-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		list-style: none;
		margin: 34px 0 0;
		padding: 0;
	}

	.category-list li,
	.theme-list li {
		background: var(--color-page);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		color: var(--color-heading);
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1;
		padding: 12px 16px;
	}

	.resource-groups {
		display: grid;
		gap: 38px;
		margin-top: 44px;
	}

	.resource-group {
		border-top: 1px solid var(--color-border);
		padding-top: 34px;
	}

	.resource-group-heading {
		margin-bottom: 22px;
		max-width: 720px;
	}

	.resource-group-heading h3 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 3vw, 2rem);
		margin: 0;
	}

	.resource-card-grid,
	.format-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.advent-audio-blocks {
		display: grid;
		gap: 20px;
	}

	.advent-audio-block {
		display: grid;
		gap: 10px;
	}

	.advent-audio-heading {
		align-items: center;
		display: flex;
		justify-content: space-between;
		gap: 16px;
	}

	.advent-audio-heading h4 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: 1.2rem;
		line-height: 1.25;
		margin: 0;
	}

	.advent-audio-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 10px;
	}

	.advent-audio-card {
		background: var(--color-surface-warm);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		color: inherit;
		display: block;
		overflow: hidden;
		text-decoration: none;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	.advent-audio-card:hover {
		border-color: var(--color-border-strong);
		transform: translateY(-2px);
	}

