---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ContentCard from '../components/ContentCard.astro';
import CtaButton from '../components/CtaButton.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import InfoCard from '../components/InfoCard.astro';
import SectionHeading from '../components/SectionHeading.astro';

const imageModules = import.meta.glob<ImageMetadata>('../assets/images/*', {
	eager: true,
	import: 'default',
});

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
const sermons = (await getCollection('sermons', ({ data }) => !data.draft)).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
const ministryItems = (await getCollection('ministry')).sort((a, b) => a.data.order - b.data.order);
const [siteEntry] = await getCollection('site');
const site = siteEntry.data;

const hero = site.hero;
const services = site.services;
const about = site.about;
const facebook = site.facebook;
const resources = site.resources;
const course = site.course;
const app = site.app;
const contactInfo = site.contact;
const articleCards = articles.filter((entry) => entry.data.category !== 'Tervis');
const healthCards = articles.filter((entry) => entry.data.category === 'Tervis');

function getImage(filename?: string) {
	if (!filename) return undefined;

	return imageModules[`../assets/images/${filename}`];
}

function getResourceEntries(key: string) {
	if (key === 'articles') return articleCards;
	if (key === 'sermons') return sermons;
	if (key === 'health') return healthCards;

	return [];
}

const heroAsset = getImage(hero.image);
const aboutAsset = getImage(about.image);
---

<html lang="et">
	<head>
		<BaseHead title={site.title} description={site.description} siteTitle={site.title} image={heroAsset} />
	</head>
	<body>
		<Header />
		<main class="page-wrapper">
			<section class="hero-section" id="home">
				<div class="hero-content">
					<div class="hero-copy">
						
						<h1>{hero.title}</h1>
						<p class="hero-intro">{hero.description}</p>
						<div class="hero-actions">
							{hero.buttons?.map((button) => (
								<CtaButton {...button} />
							))}
						</div>
					</div>
					{heroAsset && (
						<div class="hero-image-card">
							<Picture
								src={heroAsset}
								formats={['webp']}
								widths={[640, 960, 1200]}
								sizes="(max-width: 860px) calc(100vw - 36px), min(42vw, 500px)"
								alt={hero.imageAlt ?? ''}
								loading="eager"
								quality={85}
							/>
						</div>
					)}
				</div>
			</section>

			<section class="info-section" id="services">
				<div class="section-inner">
					<SectionHeading eyebrow={services.eyebrow} title={services.title} />
					<div class="info-grid">
						{services.cards?.map((card) => (
							<InfoCard {...card} />
						))}
					</div>
				</div>
			</section>

			<section class="about-section" id="about">
				<div class="about-grid">
					{aboutAsset && (
						<div class="about-image">
							<Picture
								src={aboutAsset}
								formats={['webp']}
								widths={[640, 960, 1200]}
								sizes="(max-width: 860px) calc(100vw - 36px), min(43vw, 530px)"
								alt={about.imageAlt ?? ''}
								loading="lazy"
								quality={85}
							/>
						</div>
					)}
					<div class="about-copy">
						<p class="eyebrow">{about.eyebrow}</p>
						<h2>{about.title}</h2>
						{about.description?.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
					</div>
				</div>
			</section>

			<section class="facebook-section" id="facebook">
				<div class="section-inner social-panel">
					<SectionHeading eyebrow={facebook.eyebrow} title={facebook.title} description={facebook.description} />
					{facebook.buttons?.map((button) => (
						<CtaButton {...button} />
					))}
				</div>
			</section>

			<section class="resources-section" id="materjalid">
				<div class="section-inner">
					<SectionHeading eyebrow={resources.eyebrow} title={resources.title} description={resources.description} />

					<ul class="category-list" aria-label={resources.categoriesLabel}>
						{resources.categories?.map((category) => <li>{category}</li>)}
					</ul>

					<div class="resource-groups">
						{resources.groups?.map((group) => (
							<article class="resource-group">
								<div class="resource-group-heading">
									<p class="eyebrow">{group.eyebrow}</p>
									<h3>{group.title}</h3>
								</div>
								<div class="resource-card-grid compact">
									{getResourceEntries(group.key).map((entry) => (
										<ContentCard
											title={entry.data.title}
											label={entry.data.category}
											href={`${group.key === 'sermons' ? 'sermons' : 'articles'}/${entry.id}/`}
										/>
									))}
								</div>
							</article>
						))}

						<div class="format-grid" aria-label={resources.formatsLabel}>
							{ministryItems.map((entry) => (
								<InfoCard title={entry.data.title} description={entry.data.description} />
							))}
						</div>
					</div>
				</div>
			</section>

			<section class="course-section" id="kursus">
				<div class="course-grid">
					<div>
						<p class="eyebrow">{course.eyebrow}</p>
						<h2>{course.title}</h2>
						<p class="section-description">{course.description}</p>
						<div class="course-actions">
							{course.buttons?.map((button) => (
								<CtaButton {...button} />
							))}
						</div>
					</div>
					<ul class="theme-list" aria-label={course.themesLabel}>
						{course.themes?.map((theme) => <li>{theme}</li>)}
					</ul>
				</div>
			</section>

			<section class="app-section" id="oppetykk">
				<div class="section-inner app-card">
					<div>
						<p class="eyebrow">{app.eyebrow}</p>
						<h2>{app.title}</h2>
						<p class="section-description">{app.description}</p>
					</div>
					{app.buttons?.map((button) => (
						<CtaButton {...button} />
					))}
				</div>
			</section>

			<section class="visit-section" id="contact">
				<div class="visit-inner">
					<div class="visit-copy">
						<p class="eyebrow">{contactInfo.eyebrow}</p>
						<h2>{contactInfo.title}</h2>
					</div>
					<div class="contact-card">
						<div class="visit-details">
							<h3>{contactInfo.cardTitle}</h3>
							<p><strong>{contactInfo.fields.serviceTime}:</strong> {contactInfo.serviceTime}</p>
							<p><strong>{contactInfo.fields.bibleStudyTime}:</strong> {contactInfo.bibleStudyTime}</p>
							<p><strong>{contactInfo.fields.address}:</strong> {contactInfo.address}</p>
							<p><strong>{contactInfo.fields.pastor}:</strong> {contactInfo.pastor}</p>
							<p><strong>{contactInfo.fields.phone}:</strong> <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a></p>
							<p>
								<strong>{contactInfo.fields.email}:</strong>
								<a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
							</p>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: var(--color-page);
		color: var(--color-text);
	}

	.page-wrapper {
		width: 100%;
	}

	.hero-section {
		background: linear-gradient(180deg, var(--color-page) 0%, var(--color-surface) 100%);
		padding: 82px 20px 72px;
	}

	.hero-content,
	.section-inner,
	.about-grid,
	.visit-inner {
		max-width: 1180px;
		margin: 0 auto;
	}

	.hero-content {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(340px, 0.9fr);
		gap: 56px;
		align-items: center;
	}

	.hero-copy {
		max-width: 680px;
	}

	.eyebrow {
		color: var(--color-accent);
		font-family: var(--font-heading);
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		margin: 0 0 16px;
		text-transform: uppercase;
	}

	.hero-copy h1,
	.about-copy h2,
	.visit-inner h2 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-weight: 600;
		letter-spacing: 0;
	}

	.hero-copy h1 {
		font-size: clamp(2.7rem, 6vw, 5rem);
		line-height: 1.04;
		margin: 0;
	}

	.hero-intro {
		color: var(--color-text-soft);
		font-size: 1.15rem;
		line-height: 1.75;
		margin: 28px 0 0;
		max-width: 610px;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.hero-image-card,
	.about-image {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: var(--shadow-warm);
	}

	.hero-image-card {
		aspect-ratio: 4 / 5;
	}

	.hero-image-card picture,
	.about-image picture {
		display: block;
		height: 100%;
		width: 100%;
	}

	.hero-image-card img,
	.about-image img {
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.info-section,
	.about-section,
	.facebook-section,
	.resources-section,
	.course-section,
	.app-section,
	.visit-section {
		padding: 78px 20px;
	}

	.info-section,
	.resources-section,
	.app-section {
		background: var(--color-surface);
	}

	.about-copy h2,
	.course-grid h2,
	.app-card h2,
	.visit-inner h2 {
		font-size: clamp(2rem, 4vw, 3.25rem);
		line-height: 1.12;
		margin: 0;
	}

	.section-description {
		color: var(--color-text-soft);
		font-size: 1.05rem;
		line-height: 1.75;
		margin: 22px 0 0;
		max-width: 680px;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 38px;
	}

	.about-copy p,
	.visit-details p {
		color: var(--color-text-soft);
		font-size: 1rem;
		line-height: 1.75;
		margin: 0;
	}

	.about-section {
		background: var(--color-page);
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1fr);
		gap: 58px;
		align-items: center;
	}

	.about-image {
		aspect-ratio: 5 / 4;
	}

	.about-copy p {
		margin-top: 22px;
	}

	.facebook-section {
		background: var(--color-page);
	}

	.social-panel,
	.app-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 40px;
	}

	.category-list,
	.theme-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		list-style: none;
		margin: 34px 0 0;
		padding: 0;
	}

	.category-list li,
	.theme-list li {
		background: var(--color-page);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		color: var(--color-heading);
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1;
		padding: 12px 16px;
	}

	.resource-groups {
		display: grid;
		gap: 38px;
		margin-top: 44px;
	}

	.resource-group {
		border-top: 1px solid var(--color-border);
		padding-top: 34px;
	}

	.resource-group-heading {
		margin-bottom: 22px;
		max-width: 720px;
	}

	.resource-group-heading h3 {
		color: var(--color-heading);
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 3vw, 2rem);
		margin: 0;
	}

	.resource-card-grid,
	.format-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.course-section {
		background: var(--color-page);
	}

	.course-grid {
		max-width: 1180px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.7fr);
		gap: 58px;
		align-items: center;
	}

	.course-actions {
		margin-top: 32px;
	}

	.theme-list {
		align-content: start;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		margin: 0;
		padding: 28px;
	}

	.app-card {
		background: var(--color-page);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 34px;
	}

	.visit-section {
		background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 62%, #d9791f 100%);
		color: var(--color-surface);
	}

	.visit-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.65fr);
		gap: 48px;
		align-items: start;
	}

	.visit-copy {
		max-width: 560px;
	}

	.contact-card {
		align-self: stretch;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 24px;
		padding: 18px;
	}

	.visit-section .eyebrow,
	.visit-inner h2,
	.visit-details h3,
	.visit-details p {
		color: var(--color-surface);
	}

	.visit-details {
		background: rgba(255, 255, 255, 0.16);
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 16px;
		box-shadow: 0 24px 48px rgba(0, 0, 0, 0.14);
		padding: 34px;
	}

	.visit-details h3 {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		margin: 0 0 18px;
	}

	.visit-details a {
		color: var(--color-surface);
		text-decoration-color: rgba(255, 255, 255, 0.58);
		text-underline-offset: 3px;
	}

	.visit-details a:hover {
		text-decoration-color: var(--color-surface);
	}

	.visit-details p + p {
		margin-top: 12px;
	}

	@media (max-width: 860px) {
		.hero-section {
			padding: 52px 18px 54px;
		}

		.hero-content,
		.about-grid,
		.visit-inner {
			grid-template-columns: 1fr;
			gap: 34px;
		}

		.hero-image-card {
			aspect-ratio: 16 / 11;
		}

		.info-section,
		.about-section,
		.facebook-section,
		.resources-section,
		.course-section,
		.app-section,
		.visit-section {
			padding: 56px 18px;
		}

		.info-grid,
		.resource-card-grid,
		.format-grid {
			grid-template-columns: 1fr;
		}

		.social-panel,
		.app-card {
			align-items: stretch;
			flex-direction: column;
		}

		.course-grid {
			grid-template-columns: 1fr;
			gap: 32px;
		}

		.app-card {
			padding: 28px;
		}
	}

	@media (max-width: 520px) {
		.hero-copy h1 {
			font-size: 2.35rem;
		}

		.hero-actions {
			width: 100%;
		}
	}
</style>
